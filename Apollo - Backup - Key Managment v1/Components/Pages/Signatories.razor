@page "/setup/signatories"
@rendermode InteractiveServer
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]

<PageTitle>Manage Signatories</PageTitle>

<h2>Manage Signatories</h2>
<p class="text-muted">People authorized to approve security keys.</p>
<hr />

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white">Add New Signatory</div>
            <div class="card-body">
                <EditForm Model="NewSignatory" OnValidSubmit="AddSignatory" FormName="AddSignatoryForm">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Full Name <span class="text-danger">*</span></label>
                        <InputText @bind-Value="NewSignatory.Name" class="form-control" placeholder="e.g., John Doe" />
                        <ValidationMessage For="() => NewSignatory.Name" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Contact Info / Position</label>
                        <InputText @bind-Value="NewSignatory.ContactInfo" class="form-control" placeholder="e.g., Head of Security (ext. 123)" />
                    </div>
                    
                    <button type="submit" class="btn btn-success w-100">Save Signatory</button>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Contact Info</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!SignatoriesList.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center py-4 text-muted">No signatories found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var sig in SignatoriesList)
                            {
                                <tr>
                                    <td class="fw-bold">@sig.Name</td>
                                    <td>@(string.IsNullOrEmpty(sig.ContactInfo) ? "-" : sig.ContactInfo)</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ArchiveSignatory(sig.Id)">
                                            <i class="bi bi-archive"></i> Archive
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    public Signatory NewSignatory { get; set; } = new();
    private List<Signatory> SignatoriesList = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        SignatoriesList = await Db.Signatories
            .Where(s => s.IsActive == true)
            .OrderBy(s => s.Name)
            .ToListAsync();
    }

    private async Task ArchiveSignatory(int id)
    {
        var signatoryToArchive = await Db.Signatories.FindAsync(id);
        if (signatoryToArchive != null)
        {
            signatoryToArchive.IsActive = false;
            await Db.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task AddSignatory()
    {
        Db.Signatories.Add(NewSignatory);
        await Db.SaveChangesAsync();
        
        NewSignatory = new Signatory();
        await LoadData();
    }
}