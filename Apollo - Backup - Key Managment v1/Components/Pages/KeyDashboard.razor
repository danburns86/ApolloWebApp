@page "/keys/dashboard"
@rendermode InteractiveServer
@using Apollo.Data
@using Apollo.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Key Inventory Dashboard</PageTitle>

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Key Inventory Overview</h2>
        <div class="text-muted small">Live Data from Apollo System</div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-dark text-white h-100">
                <div class="card-body">
                    <h6 class="text-uppercase small opacity-75">Total Keys</h6>
                    <h2 class="display-6 fw-bold">@TotalKeys</h2>
                    <div class="small"><i class="bi bi-key"></i> Registered Hardware</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-info text-white h-100">
                <div class="card-body">
                    <h6 class="text-uppercase small opacity-75">Available (Loose)</h6>
                    <h2 class="display-6 fw-bold">@AvailableKeys</h2>
                    <div class="small"><i class="bi bi-inbox"></i> Ready to Issue</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-secondary text-white h-100">
                <div class="card-body">
                    <h6 class="text-uppercase small opacity-75">Bound in Bunches</h6>
                    <h2 class="display-6 fw-bold">@KeysInBunches</h2>
                    <div class="small"><i class="bi bi-paperclip"></i> Attached Keys</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body">
                    <h6 class="text-uppercase small opacity-75">Unique Locks</h6>
                    <h2 class="display-6 fw-bold">@TotalLocks</h2>
                    <div class="small"><i class="bi bi-door-closed"></i> Access Points</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Recent Key Movements</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light small">
                            <tr>
                                <th class="ps-3">Item</th>
                                <th>Issued To</th>
                                <th>Date</th>
                                <th class="text-end pe-3">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in RecentTransactions)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold">@(tx.KeyRecord?.Lock?.LockCode ?? tx.Bunch?.Name ?? "Item")</td>
                                    <td>@tx.IssuedToName</td>
                                    <td class="small">@tx.IssueDate.ToString("dd/MM HH:mm")</td>
                                    <td class="text-end pe-3">
                                        <span class="badge @(tx.ReturnDate == null ? "bg-primary" : "bg-success")">
                                            @(tx.ReturnDate == null ? "OUT" : "RETURNED")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100 border-start border-warning border-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-warning">Stale Checkouts (>48h)</h5>
                </div>
                <div class="card-body p-0">
                    @if (!StaleTransactions.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-check-circle h1 d-block mb-2"></i>
                            All keys accounted for.
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var tx in StaleTransactions)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="fw-bold">@tx.IssuedToName</div>
                                            <div class="small text-muted">@(tx.KeyRecord?.Lock?.LockCode ?? tx.Bunch?.Name)</div>
                                        </div>
                                        <div class="text-end">
                                            <div class="badge bg-danger">@((DateTime.Now - tx.IssueDate).Days) Days Out</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int TotalKeys;
    private int AvailableKeys;
    private int KeysInBunches;
    private int TotalLocks;
    private List<CheckoutTransaction> RecentTransactions = new();
    private List<CheckoutTransaction> StaleTransactions = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        TotalKeys = await context.Keys.CountAsync();
        TotalLocks = await context.Locks.CountAsync();
        
        var attachedIds = await context.KeyBunchAssignments
            .Where(ka => ka.RemovedDate == null)
            .Select(ka => ka.KeyRecordId)
            .ToListAsync();
            
        AvailableKeys = await context.Keys.CountAsync(k => k.Status == "In Stock" && !attachedIds.Contains(k.Id));
        KeysInBunches = attachedIds.Count;

        RecentTransactions = await context.CheckoutTransactions
            .Include(t => t.KeyRecord).ThenInclude(k => k!.Lock)
            .Include(t => t.Bunch)
            .OrderByDescending(t => t.IssueDate)
            .Take(6)
            .ToListAsync();

        var threshold = DateTime.Now.AddHours(-48);
        StaleTransactions = await context.CheckoutTransactions
            .Include(t => t.KeyRecord).ThenInclude(k => k!.Lock)
            .Include(t => t.Bunch)
            .Where(t => t.ReturnDate == null && t.IssueDate < threshold)
            .ToListAsync();
    }
}