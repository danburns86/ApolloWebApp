@page "/audit"
@rendermode InteractiveServer
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]

<PageTitle>Compliance Audit</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>Security Audit Command Center</h2>
        <p class="text-muted mb-0">Manage formal audit campaigns and verify physical inventory.</p>
    </div>
    
    <div class="d-flex gap-2">
        <div class="bg-light p-2 rounded border d-flex align-items-center">
            <label class="me-2 fw-bold text-nowrap small"><i class="bi bi-megaphone"></i> Active Campaign:</label>
            <select class="form-select form-select-sm border-primary" @bind="ActiveCampaignId" @bind:after="LoadData">
                <option value="0">-- No Active Campaign --</option>
                @foreach (var camp in Campaigns)
                {
                    <option value="@camp.Id">@camp.Name</option>
                }
            </select>
            <button class="btn btn-sm btn-outline-primary ms-2" @onclick="OpenCreateCampaignModal"><i class="bi bi-plus"></i></button>
        </div>
    </div>
</div>

@if (ActiveCampaignId == 0)
{
    <div class="alert alert-info shadow-sm border-primary">
        <h5 class="fw-bold"><i class="bi bi-info-circle-fill me-2"></i> Select or Create an Audit Campaign</h5>
        <p class="mb-0">To begin a formal audit, please select a campaign from the dropdown above. This allows you to track completion specifically for that event.</p>
    </div>
}
else
{
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body py-2 d-flex justify-content-between align-items-center">
                    <div>
                        <input type="checkbox" class="form-check-input" id="unauditedOnly" @bind="ShowUnauditedOnly" @bind:after="LoadData" />
                        <label class="form-check-label fw-bold ms-2" for="unauditedOnly">Show Only Unaudited Items in this Campaign</label>
                    </div>
                    <span class="badge bg-primary px-3 py-2">Campaign ID: #@ActiveCampaignId</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 mb-4">
            <div class="card shadow-sm border-dark">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <span class="fw-bold"><i class="bi bi-layers-fill me-2"></i> Bunches</span>
                    <span class="badge bg-light text-dark">@BunchesToAudit.Count Items</span>
                </div>
                <div class="card-body p-0 table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light small text-uppercase">
                            <tr>
                                <th class="ps-3">Bunch Name</th>
                                <th>Issued To / Location</th>
                                <th>Keys</th>
                                <th>Last Campaign Audit</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bunch in BunchesToAudit)
                            {
                                var isAudited = bunch.OldestAuditCampaignId == ActiveCampaignId;
                                <tr class="@(isAudited ? "opacity-50 table-success" : "")">
                                    <td class="ps-3 fw-bold">@bunch.Name</td>
                                    <td>@(string.IsNullOrEmpty(bunch.IssuedToName) ? "In Storage" : bunch.IssuedToName)</td>
                                    <td><span class="badge bg-secondary">@bunch.KeyCount Keys</span></td>
                                    <td class="@(isAudited ? "text-success" : "text-danger") fw-bold">
                                        @(isAudited ? "COMPLETED" : (bunch.OldestAuditDate?.ToString("dd/MM/yy") ?? "NEVER"))
                                    </td>
                                    <td class="text-end pe-3">
                                        @if (!isAudited)
                                        {
                                            <button class="btn btn-sm btn-warning fw-bold shadow-sm" @onclick="() => OpenBunchAuditModal(bunch.Id)">
                                                <i class="bi bi-clipboard-check"></i> Audit
                                            </button>
                                        }
                                        else
                                        {
                                            <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm border-secondary">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <span class="fw-bold"><i class="bi bi-key-fill me-2"></i> Loose Keys (The "Lock Walk")</span>
                    <span class="badge bg-light text-dark">@LooseKeysGrouped.Sum(x => x.Value.Count) Items</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm align-middle mb-0">
                        <tbody>
                            @foreach (var lockGroup in LooseKeysGrouped)
                            {
                                <tr class="table-light">
                                    <td colspan="4" class="ps-3 py-2 fw-bold text-uppercase small bg-opacity-10">
                                        <i class="bi bi-door-closed-fill text-muted"></i> @lockGroup.Key.LockCode - @lockGroup.Key.Name
                                    </td>
                                </tr>
                                @foreach (var key in lockGroup.Value)
                                {
                                    var isAudited = key.LastAuditCampaignId == ActiveCampaignId;
                                    <tr class="@(isAudited ? "opacity-50" : "")">
                                        <td class="ps-5 fw-bold" style="width: 25%;">@lockGroup.Key.LockCode @key.SequenceNumber</td>
                                        <td style="width: 30%;">@(string.IsNullOrEmpty(key.IssuedToName) ? "Cabinet" : key.IssuedToName)</td>
                                        <td class="@(isAudited ? "text-success" : "text-danger") fw-bold small">
                                            @(isAudited ? "AUDITED" : (key.LastFormalAuditDate?.ToString("dd/MM/yy") ?? "NEVER"))
                                        </td>
                                        <td class="text-end pe-3">
                                            @if (!isAudited)
                                            {
                                                <button class="btn btn-sm btn-outline-warning" @onclick="() => AuditKey(key.Id)">Sign-off</button>
                                            }
                                            else
                                            {
                                                <i class="bi bi-check text-success"></i>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowBunchModal && TargetBunch != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">Auditing Bunch: @TargetBunch.Name</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => ShowBunchModal = false"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-3">Please verify that the following keys are physically attached to this ring:</p>
                    <ul class="list-group list-group-flush border rounded mb-3">
                        @foreach (var ka in TargetBunch.KeyAssignments.Where(ka => ka.RemovedDate == null))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center py-2">
                                <span><i class="bi bi-key-fill text-primary me-2"></i><strong>@ka.KeyRecord!.Lock!.LockCode @ka.KeyRecord.SequenceNumber</strong> - @ka.KeyRecord.Lock.Name</span>
                            </li>
                        }
                    </ul>
                </div>
                <div class="modal-footer bg-light d-flex justify-content-between">
                    <a href="/bunches/manage/@TargetBunch.Id" class="btn btn-outline-secondary btn-sm"><i class="bi bi-gear"></i> Manage Bunch</a>
                    <button class="btn btn-success fw-bold" @onclick="ConfirmAuditBunch">Approve All & Sign-off</button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowCreateCampaignModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content shadow">
                <div class="modal-header">
                    <h5 class="modal-title">New Audit Campaign</h5>
                    <button type="button" class="btn-close" @onclick="() => ShowCreateCampaignModal = false"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label small fw-bold">Campaign Name</label>
                    <input type="text" class="form-control" @bind="NewCampaignName" placeholder="e.g. March 2026 Audit" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary w-100" @onclick="CreateCampaign">Start Campaign</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int ActiveCampaignId = 0;
    private bool ShowUnauditedOnly = true;
    private List<AuditCampaign> Campaigns = new();
    
    public class BunchAuditDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? IssuedToName { get; set; }
        public int KeyCount { get; set; }
        public DateTime? OldestAuditDate { get; set; }
        public int? OldestAuditCampaignId { get; set; }
    }

    private List<BunchAuditDto> BunchesToAudit = new();
    private Dictionary<HardwareLock, List<KeyRecord>> LooseKeysGrouped = new();
    
    private bool ShowBunchModal = false;
    private Bunch? TargetBunch;
    private bool ShowCreateCampaignModal = false;
    private string NewCampaignName = "";

    protected override async Task OnInitializedAsync()
    {
        Campaigns = await Db.AuditCampaigns.OrderByDescending(c => c.CreatedAt).ToListAsync();
        if (Campaigns.Any()) ActiveCampaignId = Campaigns.First().Id;
        await LoadData();
    }

    private async Task LoadData()
    {
        if (ActiveCampaignId == 0) return;

        var attachedKeyIds = await Db.KeyBunchAssignments.Where(ka => ka.RemovedDate == null).Select(ka => ka.KeyRecordId).ToListAsync();
        
        var keysQuery = Db.Keys.Include(k => k.Lock).Where(k => k.Status != "Lost" && !attachedKeyIds.Contains(k.Id));
        if (ShowUnauditedOnly) keysQuery = keysQuery.Where(k => k.LastAuditCampaignId != ActiveCampaignId);

        var looseKeys = await keysQuery.ToListAsync();
        LooseKeysGrouped = looseKeys.GroupBy(k => k.Lock!).ToDictionary(g => g.Key, g => g.ToList());

        var allBunches = await Db.Bunches.Include(b => b.KeyAssignments!).ThenInclude(ka => ka.KeyRecord).ThenInclude(k => k.Lock).Where(b => b.IsActive && !b.IsLost).ToListAsync();
        BunchesToAudit.Clear();

        foreach (var b in allBunches)
        {
            var activeKeys = b.KeyAssignments!.Where(ka => ka.RemovedDate == null && ka.KeyRecord != null).Select(ka => ka.KeyRecord!).ToList();
            if (!activeKeys.Any()) continue;

            var oldestCampaign = activeKeys.Min(k => k.LastAuditCampaignId);
            if (ShowUnauditedOnly && oldestCampaign == ActiveCampaignId) continue;

            BunchesToAudit.Add(new BunchAuditDto
            {
                Id = b.Id,
                Name = b.Name,
                IssuedToName = b.IssuedToName,
                KeyCount = activeKeys.Count,
                OldestAuditDate = activeKeys.Min(k => k.LastFormalAuditDate),
                OldestAuditCampaignId = oldestCampaign
            });
        }
    }

    private async Task OpenBunchAuditModal(int id)
    {
        TargetBunch = await Db.Bunches.Include(b => b.KeyAssignments!).ThenInclude(ka => ka.KeyRecord).ThenInclude(k => k.Lock).FirstAsync(b => b.Id == id);
        ShowBunchModal = true;
    }

    private async Task ConfirmAuditBunch()
    {
        if (TargetBunch == null) return;
        foreach (var ka in TargetBunch.KeyAssignments.Where(a => a.RemovedDate == null))
        {
            ka.KeyRecord!.LastFormalAuditDate = DateTime.Now;
            ka.KeyRecord.LastAuditCampaignId = ActiveCampaignId;
            ka.KeyRecord.LastSeenDate = DateTime.Now;
        }
        await Db.SaveChangesAsync();
        ShowBunchModal = false;
        await LoadData();
    }

    private async Task AuditKey(int id)
    {
        var k = await Db.Keys.FindAsync(id);
        if (k != null)
        {
            k.LastFormalAuditDate = DateTime.Now;
            k.LastAuditCampaignId = ActiveCampaignId;
            k.LastSeenDate = DateTime.Now;
            await Db.SaveChangesAsync();
            await LoadData();
        }
    }

    private void OpenCreateCampaignModal() { NewCampaignName = $"{DateTime.Now:MMMM yyyy} Audit"; ShowCreateCampaignModal = true; }
    private async Task CreateCampaign()
    {
        if (string.IsNullOrWhiteSpace(NewCampaignName)) return;
        var c = new AuditCampaign { Name = NewCampaignName };
        Db.AuditCampaigns.Add(c);
        await Db.SaveChangesAsync();
        Campaigns = await Db.AuditCampaigns.OrderByDescending(x => x.CreatedAt).ToListAsync();
        ActiveCampaignId = c.Id;
        ShowCreateCampaignModal = false;
        await LoadData();
    }
}