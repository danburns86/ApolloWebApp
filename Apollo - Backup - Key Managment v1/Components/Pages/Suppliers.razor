@page "/setup/suppliers"
@rendermode InteractiveServer
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]

<PageTitle>Manage Suppliers</PageTitle>

<h2>Manage Suppliers & Locksmiths</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">Add New Supplier</div>
            <div class="card-body">
                <EditForm Model="NewSupplier" OnValidSubmit="AddSupplier" FormName="AddSupplierForm">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Company Name <span class="text-danger">*</span></label>
                        <InputText @bind-Value="NewSupplier.Name" class="form-control" placeholder="e.g., Bob's Locks" />
                        <ValidationMessage For="() => NewSupplier.Name" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Phone Number</label>
                        <InputText @bind-Value="NewSupplier.Phone" class="form-control" placeholder="Optional" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <InputText @bind-Value="NewSupplier.Email" type="email" class="form-control" placeholder="Optional" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Physical Address</label>
                        <InputTextArea @bind-Value="NewSupplier.Address" class="form-control" rows="2" placeholder="Optional" />
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">Save Supplier</button>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!SuppliersList.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">No suppliers found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var supplier in SuppliersList)
                            {
                                <tr>
                                    <td class="fw-bold">@supplier.Name</td>
                                    <td>@(string.IsNullOrEmpty(supplier.Phone) ? "-" : supplier.Phone)</td>
                                    <td>@(string.IsNullOrEmpty(supplier.Email) ? "-" : supplier.Email)</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ArchiveSupplier(supplier.Id)">
                                            <i class="bi bi-archive"></i> Archive
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    public Supplier NewSupplier { get; set; } = new();
    private List<Supplier> SuppliersList = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        SuppliersList = await Db.Suppliers
            .Where(s => s.IsActive == true)
            .OrderBy(s => s.Name)
            .ToListAsync();
    }

    private async Task ArchiveSupplier(int id)
    {
        var supplierToArchive = await Db.Suppliers.FindAsync(id);
        if (supplierToArchive != null)
        {
            supplierToArchive.IsActive = false;
            await Db.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task AddSupplier()
    {
        Db.Suppliers.Add(NewSupplier);
        await Db.SaveChangesAsync();
        
        NewSupplier = new Supplier();
        await LoadData();
    }
}