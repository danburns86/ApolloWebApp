@page "/keys"
@rendermode InteractiveServer
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]

<PageTitle>Manage Keys</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>Key Inventory</h2>
        <p class="text-muted mb-0">Generate, audit, and manage physical keys by lock.</p>
    </div>
    
    <div class="d-flex align-items-center">
        <label class="fw-bold me-2 text-nowrap">Filter Status:</label>
        <select class="form-select shadow-sm" @bind="FilterStatus">
            <option value="All">All Keys</option>
            <option value="In Stock">In Stock Only</option>
            <option value="Issued">Issued Only</option>
            <option value="Damaged">Damaged Only</option>
            <option value="Lost">Lost Only</option>
        </select>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-3 col-lg-4 mb-4">
        <div class="card shadow-sm border-primary mb-3">
            <div class="card-header bg-primary text-white fw-bold">Cut New Keys</div>
            <div class="card-body">
                <EditForm Model="Generator" OnValidSubmit="GenerateKeys" FormName="GenerateKeysForm">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Hardware Lock <span class="text-danger">*</span></label>
                        <InputSelect @bind-Value="Generator.LockId" class="form-select">
                            <option value="0">-- Choose a Lock --</option>
                            @foreach (var lck in LocksList)
                            {
                                <option value="@lck.Id">@lck.LockCode - @lck.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => Generator.LockId" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Initial Storage <span class="text-danger">*</span></label>
                        <InputSelect @bind-Value="Generator.StorageLocationId" class="form-select">
                            <option value="0">-- Select Cabinet/Safe --</option>
                            @foreach (var loc in LocationsList)
                            {
                                <option value="@loc.Id">@loc.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => Generator.StorageLocationId" class="text-danger" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Quantity <span class="text-danger">*</span></label>
                        <InputNumber @bind-Value="Generator.Quantity" class="form-control" min="1" max="50" />
                        <ValidationMessage For="() => Generator.Quantity" class="text-danger" />
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-key-fill"></i> Generate Keys
                    </button>
                </EditForm>
            </div>
        </div>

        @if (SelectedKeyIds.Any())
        {
            <div class="card shadow border-warning">
                <div class="card-body bg-warning bg-opacity-10 text-center">
                    <h5 class="fw-bold text-dark mb-2">@SelectedKeyIds.Count Keys Selected</h5>
                    <button class="btn btn-dark w-100 shadow-sm" @onclick="OpenBulkEditModal">
                        <i class="bi bi-pencil-square"></i> Bulk Edit Selected
                    </button>
                </div>
            </div>
        }
    </div>

    <div class="col-xl-9 col-lg-8">
        @if (!GroupedKeys.Any())
        {
            <div class="alert alert-secondary text-center shadow-sm py-4">
                No keys found matching the current filter.
            </div>
        }
        else
        {
            @foreach (var lockGroup in GroupedKeys.OrderBy(g => g.Key.LockCode))
            {
                var filteredKeys = lockGroup.Value.Where(k => FilterStatus == "All" || k.Status == FilterStatus).ToList();
                
                if (!filteredKeys.Any()) continue;

                <div class="card mb-4 shadow-sm border-0">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <span class="fw-bold"><i class="bi bi-lock-fill me-2"></i> Lock: @lockGroup.Key.LockCode - @lockGroup.Key.Name</span>
                        <div>
                            <button class="btn btn-sm btn-outline-light me-2" @onclick="() => SelectAllInLock(filteredKeys)">Select All</button>
                            <span class="badge bg-secondary">@filteredKeys.Count Keys</span>
                        </div>
                    </div>
                    <div class="card-body p-0 table-responsive">
                        <table class="table table-sm table-striped table-hover align-middle mb-0">
                            <thead class="table-light text-muted small text-uppercase">
                                <tr>
                                    <th class="ps-3" style="width: 40px;"></th>
                                    <th>Key Number</th>
                                    <th>Location</th>
                                    <th>Status</th>
                                    <th>Last Seen</th>
                                    <th class="text-end pe-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var key in filteredKeys.OrderBy(k => k.SequenceNumber))
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <input class="form-check-input" type="checkbox"
                                                   checked="@SelectedKeyIds.Contains(key.Id)"
                                                   @onchange="(e) => ToggleKeySelection(key.Id, e.Value)" />
                                        </td>
                                        <td class="fw-bold fs-6">@lockGroup.Key.LockCode @key.SequenceNumber</td>
                                        <td><i class="bi bi-box-seam me-1 text-muted"></i> @(key.StorageLocation?.Name ?? "-")</td>
                                        <td>
                                            @if (key.Status == "In Stock")
                                            {
                                                <span class="badge bg-success">In Stock</span>
                                            }
                                            else if (key.Status == "Issued")
                                            {

                                                <span class="badge bg-info text-dark">Issued</span>
                                            }
                                            else if (key.Status == "Damaged")
                                            {

                                                <span class="badge bg-warning text-dark">Damaged</span>
                                            }
                                            else if (key.Status == "Lost")
                                            {

                                                <span class="badge bg-danger">Lost</span>
                                            }
                                            else
                                            {

                                                <span class="badge bg-secondary">@key.Status</span>
                                            }
                                        </td>
                                        <td class="small">@(key.LastSeenDate?.ToString("dd/MM/yyyy") ?? "Never")</td>
                                        <td class="text-end pe-3">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => EditSingleKey(key)">
                                                <i class="bi bi-pencil"></i> Edit
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    </div>
</div>

@if (ShowEditModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content shadow">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">Edit @SelectedKeyIds.Count Key(s)</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseEditModal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2 small mb-3">
                        <i class="bi bi-info-circle me-1"></i> Changes made here will apply to all selected keys. Leave a dropdown as "No Change" to keep existing values.
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Update Storage Location</label>
                        <select class="form-select" @bind="EditModel.StorageLocationId">
                            <option value="0">-- No Change --</option>
                            @foreach (var loc in LocationsList)
                            {
                                <option value="@loc.Id">@loc.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Update Status</label>
                        <select class="form-select" @bind="EditModel.Status">
                            <option value="">-- No Change --</option>
                            <option value="In Stock">In Stock</option>
                            <option value="Damaged">Damaged</option>
                            <option value="Lost">Lost</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseEditModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveBulkEdit">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowConflictModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.7); z-index: 1060;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-danger shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-octagon me-2"></i>Bunch Conflict Detected</h5>
                </div>
                <div class="modal-body">
                    <p>You are trying to change the status/location of <strong>@BunchedKeysInConflict.Count</strong> keys that are currently assigned to bunches.</p>
                    <p class="text-muted small">Keys on bunches cannot be moved to "In Stock" or "Damaged" without being removed from their bunch first.</p>
                    
                    <div class="list-group list-group-flush mb-3 border rounded" style="max-height: 150px; overflow-y: auto;">
                        @foreach (var k in BunchedKeysInConflict)
                        {
                            <div class="list-group-item small">@k.Lock?.LockCode @k.SequenceNumber (on @k.BunchAssignments.FirstOrDefault(ba => ba.RemovedDate == null)?.Bunch?.Name)</div>
                        }
                    </div>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-outline-secondary" @onclick="() => ShowConflictModal = false">Cancel</button>
                    <button type="button" class="btn btn-warning" @onclick="() => ProcessBulkEdit(true)">Skip Bunched Keys</button>
                    <button type="button" class="btn btn-danger" @onclick="() => ProcessBulkEdit(false)">Remove from Bunches & Save</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    public class KeyGenerationForm
    {
        public int LockId { get; set; }
        public int StorageLocationId { get; set; }
        public int Quantity { get; set; } = 1;
    }

    public class BulkEditForm
    {
        public int StorageLocationId { get; set; } = 0;
        public string Status { get; set; } = "";
    }

    public KeyGenerationForm Generator { get; set; } = new();
    public BulkEditForm EditModel { get; set; } = new();
    
    private List<HardwareLock> LocksList = new();
    private List<StorageLocation> LocationsList = new();
    private Dictionary<HardwareLock, List<KeyRecord>> GroupedKeys = new();

    private string FilterStatus = "All";
    private HashSet<int> SelectedKeyIds = new();
    private bool ShowEditModal = false;
    private bool ShowConflictModal = false;
    private List<KeyRecord> BunchedKeysInConflict = new();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        LocksList = await Db.Locks.Where(l => l.IsActive).OrderBy(l => l.LockCode).ToListAsync();
        LocationsList = await Db.StorageLocations.Where(s => s.IsActive).OrderBy(s => s.Name).ToListAsync();
        
        var allKeys = await Db.Keys
            .Include(k => k.Lock)
            .Include(k => k.StorageLocation)
            .Include(k => k.BunchAssignments).ThenInclude(ba => ba.Bunch)
            .Where(k => k.Lock != null)
            .ToListAsync();

        GroupedKeys = allKeys.GroupBy(k => k.Lock!).ToDictionary(g => g.Key, g => g.ToList());
    }

    private async Task GenerateKeys()
    {
        var currentMaxSequence = await Db.Keys.Where(k => k.LockId == Generator.LockId).MaxAsync(k => (int?)k.SequenceNumber) ?? 0;
        for (int i = 1; i <= Generator.Quantity; i++)
        {
            Db.Keys.Add(new KeyRecord { LockId = Generator.LockId, StorageLocationId = Generator.StorageLocationId, SequenceNumber = currentMaxSequence + i, Status = "In Stock", LastSeenDate = DateTime.Now });
        }
        await Db.SaveChangesAsync();
        Generator = new KeyGenerationForm();
        await LoadData();
    }

    private void ToggleKeySelection(int keyId, object? isChecked)
    {
        if (isChecked is bool check && check) SelectedKeyIds.Add(keyId);
        else SelectedKeyIds.Remove(keyId);
    }

    private void SelectAllInLock(List<KeyRecord> keysInLock)
    {
        var allSelected = keysInLock.All(k => SelectedKeyIds.Contains(k.Id));
        foreach (var k in keysInLock) { if (allSelected) SelectedKeyIds.Remove(k.Id); else SelectedKeyIds.Add(k.Id); }
    }

    private void EditSingleKey(KeyRecord key) { SelectedKeyIds.Clear(); SelectedKeyIds.Add(key.Id); OpenBulkEditModal(); }
    private void OpenBulkEditModal() { EditModel = new BulkEditForm(); ShowEditModal = true; }
    private void CloseEditModal() { ShowEditModal = false; SelectedKeyIds.Clear(); }

    private async Task SaveBulkEdit()
    {
        if (!SelectedKeyIds.Any()) return;
        var keysToUpdate = await Db.Keys.Include(k => k.Lock).Include(k => k.BunchAssignments).ThenInclude(ba => ba.Bunch).Where(k => SelectedKeyIds.Contains(k.Id)).ToListAsync();
        BunchedKeysInConflict = keysToUpdate.Where(k => k.BunchAssignments.Any(ba => ba.RemovedDate == null)).ToList();

        if (BunchedKeysInConflict.Any() && !string.IsNullOrEmpty(EditModel.Status) && EditModel.Status != "Lost")
            ShowConflictModal = true;
        else
            await ProcessBulkEdit(false);
    }

    private async Task ProcessBulkEdit(bool skipBunched)
    {
        var keysToUpdate = await Db.Keys.Include(k => k.BunchAssignments).Where(k => SelectedKeyIds.Contains(k.Id)).ToListAsync();
        foreach (var key in keysToUpdate)
        {
            bool isBunched = key.BunchAssignments.Any(ba => ba.RemovedDate == null);
            if (skipBunched && isBunched) continue;
            if (isBunched && !string.IsNullOrEmpty(EditModel.Status) && EditModel.Status != "Lost")
            {
                var active = key.BunchAssignments.FirstOrDefault(ba => ba.RemovedDate == null);
                if (active != null) active.RemovedDate = DateTime.Now;
            }
            if (EditModel.StorageLocationId != 0) key.StorageLocationId = EditModel.StorageLocationId;
            if (!string.IsNullOrEmpty(EditModel.Status))
            {
                key.Status = EditModel.Status;
                key.IsLostLockout = (key.Status == "Lost");
                key.LastSeenDate = DateTime.Now;
            }
        }
        await Db.SaveChangesAsync();
        ShowConflictModal = false;
        CloseEditModal();
        await LoadData();
    }
}