@page "/locks"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]

<PageTitle>Manage Locks</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>Manage Hardware Locks</h2>
        <p class="text-muted mb-0">Create, swap, and manage physical locks, locksmiths, and authorized signatories.</p>
    </div>
</div>
<hr />

<div class="row">
    <div class="col-xl-4 col-lg-5 mb-4">
        
        <div class="card shadow-sm border-info mb-3">
            <div class="card-body py-2 bg-light">
                <strong class="small text-uppercase text-muted">Available Primary Letters:</strong>
                <div class="mt-1" style="font-size: 0.9rem;">
                    @if (UnusedPrefixes.Any())
                    {
                        @foreach (var letter in UnusedPrefixes)
                        {
                            <span class="badge bg-white text-primary border border-primary me-1 mb-1 shadow-sm hover-badge"
                                  style="cursor:pointer;"
                                  @onclick="() => SetLockCode(letter)">@letter</span>
                        }
                    }
                    else
                    {
                        <span class="text-danger small">All A-Z prefixes are currently in use!</span>
                    }
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white fw-bold">Register New Lock</div>
            <div class="card-body">
                <EditForm Model="NewLock" OnValidSubmit="AddLock" FormName="AddHardwareLockForm">
                    <DataAnnotationsValidator />
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Lock Code <span class="text-danger">*</span></label>
                            <InputText @bind-Value="NewLock.LockCode" class="form-control" placeholder="e.g. A, B*" />
                            @if (!string.IsNullOrEmpty(CodeErrorMessage))
                            {
                                <div class="text-danger small mt-1 fw-bold">@CodeErrorMessage</div>
                            }
                            <ValidationMessage For="() => NewLock.LockCode" class="text-danger" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Key Code</label>
                            <InputText @bind-Value="NewLock.KeyCode" class="form-control" placeholder="From locksmith" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Door Name / Location <span class="text-danger">*</span></label>
                        <InputText @bind-Value="NewLock.Name" class="form-control" placeholder="e.g. Front Door Top Lock" />
                        <ValidationMessage For="() => NewLock.Name" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Form Factor <span class="text-danger">*</span></label>
                        <InputSelect @bind-Value="NewLock.FormFactorId" class="form-select">
                            <option value="0">-- Select a Form Factor --</option>
                            @foreach (var ff in FormFactors)
                            {
                                <option value="@ff.Id">@ff.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => NewLock.FormFactorId" class="text-danger" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Locksmith / Supplier</label>
                            <InputSelect @bind-Value="NewLock.SupplierId" class="form-select form-select-sm">
                                <option value="">-- None --</option>
                                @foreach (var sup in Suppliers)
                                {
                                    <option value="@sup.Id">@sup.Name</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Auth. Signatories</label>
                            <div class="border rounded p-2 bg-light" style="height: 80px; overflow-y: auto;">
                                @if (!AllSignatories.Any())
                                {
                                    <span class="text-muted small">None defined.</span>
                                }
                                @foreach (var sig in AllSignatories)
                                {
                                    <div class="form-check mb-0">
                                        <input class="form-check-input" type="checkbox" id="newsig_@sig.Id"
                                               checked="@NewLockSignatoryIds.Contains(sig.Id)"
                                               @onchange="@(e => { if ((bool)(e.Value ?? false)) NewLockSignatoryIds.Add(sig.Id); else NewLockSignatoryIds.Remove(sig.Id); })" />
                                        <label class="form-check-label small" for="newsig_@sig.Id">@sig.Name</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <InputSelect @bind-Value="NewLock.Status" class="form-select">
                            <option value="Active">Active (Installed)</option>
                            <option value="Stock">In Stock (Spare/Swapped)</option>
                            <option value="Retired">Retired</option>
                        </InputSelect>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">Register Lock</button>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-xl-8 col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-body p-0 table-responsive">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead class="table-dark small text-uppercase">
                        <tr>
                            <th class="ps-3">Code</th>
                            <th>Door Name / Location</th>
                            <th>Security Info</th>
                            <th>Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!LocksList.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No locks registered yet. Add one to the left!</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var lck in LocksList)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold text-primary fs-5">@lck.LockCode</td>
                                    <td class="fw-bold">
                                        @lck.Name
                                        <div class="small fw-normal text-muted">Type: @(lck.FormFactor?.Name ?? "Unknown")</div>
                                    </td>
                                    <td>
                                        @if (lck.Supplier != null)
                                        {
                                            <div class="small fw-bold text-dark"><i class="bi bi-truck me-1"></i>@lck.Supplier.Name</div>
                                        }
                                        @if (lck.Signatories.Any())
                                        {
                                            <div class="small text-muted"><i class="bi bi-pen me-1"></i>@lck.Signatories.Count Auth.</div>
                                        }
                                        @if (lck.Supplier == null && !lck.Signatories.Any())
                                        {
                                            <span class="text-muted small">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (lck.Status == "Active")
                                        {
                                            <span class="badge bg-success">Installed</span>
                                        }
                                        else if (lck.Status == "Stock")
                                        {
                                            <span class="badge bg-warning text-dark">In Stock</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Retired</span>
                                        }
                                    </td>
                                    <td class="text-end pe-3">
                                        <button type="button" class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenEditModal(lck)">
                                            <i class="bi bi-pencil"></i> Edit
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ArchiveLock(lck.Id)">
                                            <i class="bi bi-archive"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (ShowEditModal && EditingLock != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content shadow-lg border-primary">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">Edit Lock: @EditingLock.LockCode</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseEditModal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info small py-2 mb-3">
                        <i class="bi bi-info-circle me-1"></i> Swap this lock out by changing its status to <strong>In Stock</strong> and clearing the Door Name.
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Door Name / Location</label>
                        <input type="text" class="form-control" @bind="EditingLock.Name" placeholder="e.g. In Cabinet, Spare, or New Door" />
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Locksmith / Supplier</label>
                            <select class="form-select form-select-sm" @bind="EditingLock.SupplierId">
                                <option value="">-- No Specific Supplier --</option>
                                @foreach (var sup in Suppliers)
                                {
                                    <option value="@sup.Id">@sup.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Auth. Signatories</label>
                            <div class="border rounded p-2 bg-light" style="max-height: 100px; overflow-y: auto;">
                                @if (!AllSignatories.Any())
                                {
                                    <span class="text-muted small">None defined.</span>
                                }
                                @foreach (var sig in AllSignatories)
                                {
                                    <div class="form-check mb-0">
                                        <input class="form-check-input" type="checkbox" id="editsig_@sig.Id"
                                               checked="@EditLockSignatoryIds.Contains(sig.Id)"
                                               @onchange="@(e => { if ((bool)(e.Value ?? false)) EditLockSignatoryIds.Add(sig.Id); else EditLockSignatoryIds.Remove(sig.Id); })" />
                                        <label class="form-check-label small" for="editsig_@sig.Id">@sig.Name</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Key Code</label>
                            <input type="text" class="form-control" @bind="EditingLock.KeyCode" placeholder="From locksmith" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Current Status</label>
                            <select class="form-select" @bind="EditingLock.Status">
                                <option value="Active">Active (Installed)</option>
                                <option value="Stock">In Stock (Spare/Swapped)</option>
                                <option value="Retired">Retired</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseEditModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveEditedLock">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .hover-badge:hover {
        background-color: #0d6efd !important;
        color: white !important;
    }
</style>

@code {
    public HardwareLock NewLock { get; set; } = new();
    
    private List<FormFactor> FormFactors = new();
    private List<Supplier> Suppliers = new();
    private List<Signatory> AllSignatories = new();
    
    private List<HardwareLock> LocksList = new();
    private List<char> UnusedPrefixes = new();
    
    // Tracks checkbox selections
    private List<int> NewLockSignatoryIds = new();
    private List<int> EditLockSignatoryIds = new();

    private string? CodeErrorMessage;
    private bool ShowEditModal = false;
    private HardwareLock? EditingLock;

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
        await LoadLocks();
    }

    private async Task LoadLookupData()
    {
        FormFactors = await Db.FormFactors.Where(f => f.IsActive).OrderBy(f => f.Name).ToListAsync();
        Suppliers = await Db.Suppliers.Where(s => s.IsActive).OrderBy(s => s.Name).ToListAsync();
        AllSignatories = await Db.Signatories.Where(s => s.IsActive).OrderBy(s => s.Name).ToListAsync();
    }

    private async Task LoadLocks()
    {
        LocksList = await Db.Locks
            .Include(l => l.FormFactor)
            .Include(l => l.Supplier)
            .Include(l => l.Signatories) // Include Signatories relationship!
            .Where(l => l.IsActive == true)
            .OrderBy(l => l.LockCode)
            .ToListAsync();
            
        CalculateUnusedPrefixes();
    }
    
    private void CalculateUnusedPrefixes()
    {
        var alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".ToList();
        var usedLetters = LocksList
            .Where(l => !string.IsNullOrWhiteSpace(l.LockCode) && (l.Status == "Active" || l.Status == "Stock"))
            .Select(l => l.LockCode.ToUpper()[0])
            .Distinct()
            .ToList();

        UnusedPrefixes = alphabet.Except(usedLetters).ToList();
    }

    private void SetLockCode(char letter)
    {
        NewLock.LockCode = letter.ToString();
        CodeErrorMessage = null;
    }

    private async Task AddLock()
    {
        CodeErrorMessage = null;
        if (NewLock.FormFactorId == 0) return;

        var codeInUse = await Db.Locks.AnyAsync(l =>
            l.LockCode.ToUpper() == NewLock.LockCode.ToUpper() &&
            l.IsActive &&
            (l.Status == "Active" || l.Status == "Stock"));

        if (codeInUse)
        {
            CodeErrorMessage = $"The lock code '{NewLock.LockCode}' is already assigned to an Active or In-Stock lock.";
            return;
        }

        // Hydrate the many-to-many relationship before saving
        NewLock.Signatories = await Db.Signatories.Where(s => NewLockSignatoryIds.Contains(s.Id)).ToListAsync();

        Db.Locks.Add(NewLock);
        await Db.SaveChangesAsync();
        
        NewLock = new HardwareLock();
        NewLockSignatoryIds.Clear();
        await LoadLocks();
    }

    private void OpenEditModal(HardwareLock lck)
    {
        EditingLock = lck;
        EditLockSignatoryIds = lck.Signatories.Select(s => s.Id).ToList();
        ShowEditModal = true;
    }

    private void CloseEditModal()
    {
        ShowEditModal = false;
        EditingLock = null;
    }

    private async Task SaveEditedLock()
    {
        if (EditingLock != null)
        {
            // Clear old signatories and attach the newly checked ones
            EditingLock.Signatories.Clear();
            var newSigs = await Db.Signatories.Where(s => EditLockSignatoryIds.Contains(s.Id)).ToListAsync();
            foreach (var sig in newSigs)
            {
                EditingLock.Signatories.Add(sig);
            }

            Db.Locks.Update(EditingLock);
            await Db.SaveChangesAsync();
            
            CloseEditModal();
            await LoadLocks();
        }
    }

    private async Task ArchiveLock(int id)
    {
        var lockToArchive = await Db.Locks.FindAsync(id);
        if (lockToArchive != null)
        {
            lockToArchive.IsActive = false;
            await Db.SaveChangesAsync();
            await LoadLocks();
        }
    }
}