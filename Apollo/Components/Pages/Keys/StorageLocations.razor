@page "/setup/locations"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]

<PageTitle>Storage Locations</PageTitle>

<h2>Manage Storage Locations</h2>
<p class="text-muted">Define physical locations where keys and bunches are kept (e.g., Foyer Cupboard, Tech Safe).</p>
<hr />

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">Add New Location</div>
            <div class="card-body">
                <EditForm Model="NewLocation" OnValidSubmit="AddLocation" FormName="AddLocationForm">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Location Name <span class="text-danger">*</span></label>
                        <InputText @bind-Value="NewLocation.Name" class="form-control" placeholder="e.g., Main Foyer Cupboard" />
                        <ValidationMessage For="() => NewLocation.Name" class="text-danger" />
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">Save Location</button>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Location Name</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!LocationsList.Any())
                        {
                            <tr>
                                <td colspan="2" class="text-center py-4 text-muted">No locations found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var loc in LocationsList)
                            {
                                <tr>
                                    <td class="fw-bold">@loc.Name</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ArchiveLocation(loc.Id)">
                                            <i class="bi bi-archive"></i> Archive
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    public StorageLocation NewLocation { get; set; } = new();
    private List<StorageLocation> LocationsList = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        LocationsList = await Db.StorageLocations
            .Where(s => s.IsActive == true)
            .OrderBy(s => s.Name)
            .ToListAsync();
    }

    private async Task ArchiveLocation(int id)
    {
        var locToArchive = await Db.StorageLocations.FindAsync(id);
        if (locToArchive != null)
        {
            locToArchive.IsActive = false;
            await Db.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task AddLocation()
    {
        Db.StorageLocations.Add(NewLocation);
        await Db.SaveChangesAsync();
        NewLocation = new StorageLocation();
        await LoadData();
    }
}