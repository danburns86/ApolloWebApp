@page "/setup/formfactors"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]

<PageTitle>Manage Form Factors</PageTitle>

<h2>Manage Form Factors</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Add New</div>
            <div class="card-body">
                <EditForm Model="NewFormFactor" OnValidSubmit="AddFormFactor">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-3">
                        <label class="form-label">Form Factor Name</label>
                        <InputText @bind-Value="NewFormFactor.Name" class="form-control" placeholder="e.g., Cylinder" />
                        <ValidationMessage For="() => NewFormFactor.Name" class="text-danger" />
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">Save</button>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Form Factor Name</th>
                </tr>
            </thead>
            <tbody>
                @if (!FormFactorsList.Any())
                {
                    <tr>
                        <td colspan="2" class="text-center">No form factors found. Add one to the left!</td>
                    </tr>
                }
                else
                {
                    @foreach (var ff in FormFactorsList)
                    {
                        <tr>
                            <td>@ff.Id</td>
                            <td>@ff.Name</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    public FormFactor NewFormFactor { get; set; } = new();

    private List<FormFactor> FormFactorsList = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        // Fetches all form factors from the SQL database
        FormFactorsList = await Db.FormFactors.ToListAsync();
    }

    private async Task AddFormFactor()
    {
        // Save to database
        Db.FormFactors.Add(NewFormFactor);
        await Db.SaveChangesAsync();
        
        // Reset the form and refresh the table instantly
        NewFormFactor = new FormFactor();
        await LoadData();
    }
}