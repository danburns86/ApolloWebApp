@page "/admin/reports/spare-locks"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Spare Locks Report</PageTitle>

<div class="d-print-none mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h2>Spare Locks & Hardware Stock</h2>
        <p class="text-muted mb-0">Unallocated locks available for installation, including their retained keys.</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="groupToggle" @bind="GroupByFormFactor" />
            <label class="form-check-label fw-bold small" for="groupToggle">Group by Form Factor</label>
        </div>
        <button class="btn btn-outline-dark shadow-sm" onclick="window.print()">
            <i class="bi bi-printer me-2"></i> Print
        </button>
    </div>
</div>

@if (!SpareLocks.Any())
{
    <div class="alert alert-info text-center">No spare or retired locks currently in the system.</div>
}
else
{
    @if (GroupByFormFactor)
    {
        @foreach (var group in SpareLocks.GroupBy(l => l.FormFactor?.Name ?? "Unknown Type").OrderBy(g => g.Key))
        {
            <div class="card shadow-sm border-0 mb-4" style="page-break-inside: avoid;">
                <div class="card-header bg-dark text-white fw-bold">
                    <i class="bi bi-tools me-2"></i> Form Factor: @group.Key
                </div>
                <div class="card-body p-0 table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <thead class="table-light small text-uppercase">
                            <tr>
                                <th class="ps-3">Lock Code</th>
                                <th>Previous Name / Notes</th>
                                <th>Factory Code</th>
                                <th>Status</th>
                                <th class="text-center border-start">Total Keys</th>
                                <th class="text-center text-info">Iss.</th>
                                <th class="text-center text-success">Stk.</th>
                                <th class="text-center text-warning">Dmg.</th>
                                <th class="text-center text-danger pe-3">Lost</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lck in group)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold fs-6 text-primary">@lck.LockCode</td>
                                    <td class="small">@(string.IsNullOrEmpty(lck.Name) ? "-" : lck.Name)</td>
                                    <td class="font-monospace small">@(string.IsNullOrEmpty(lck.KeyCode) ? "Unknown" : lck.KeyCode)</td>
                                    <td>
                                        <span class="badge @(lck.Status == "Stock" ? "bg-warning text-dark" : "bg-secondary")">
                                            @(lck.Status == "Stock" ? "Ready" : "Retired")
                                        </span>
                                    </td>
                                    <td class="text-center fw-bold bg-light border-start">@lck.Keys.Count</td>
                                    <td class="text-center">@lck.Keys.Count(k => k.Status == "Issued")</td>
                                    <td class="text-center">@lck.Keys.Count(k => k.Status == "In Stock")</td>
                                    <td class="text-center">@lck.Keys.Count(k => k.Status == "Damaged")</td>
                                    <td class="text-center pe-3 fw-bold @(lck.Keys.Any(k => k.Status == "Lost") ? "text-danger" : "")">
                                        @lck.Keys.Count(k => k.Status == "Lost")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0 table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-dark small text-uppercase">
                        <tr>
                            <th class="ps-3">Lock Code</th>
                            <th>Previous Name / Notes</th>
                            <th>Form Factor</th>
                            <th>Status</th>
                            <th class="text-center border-start border-secondary">Total Keys</th>
                            <th class="text-center text-info">Iss.</th>
                            <th class="text-center text-success">Stk.</th>
                            <th class="text-center text-warning">Dmg.</th>
                            <th class="text-center text-danger pe-3">Lost</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lck in SpareLocks.OrderBy(l => l.LockCode))
                        {
                            <tr>
                                <td class="ps-3 fw-bold fs-6 text-primary">@lck.LockCode</td>
                                <td class="small">@(string.IsNullOrEmpty(lck.Name) ? "-" : lck.Name)</td>
                                <td class="small">@(lck.FormFactor?.Name ?? "Unknown")</td>
                                <td>
                                    <span class="badge @(lck.Status == "Stock" ? "bg-warning text-dark" : "bg-secondary")">
                                        @(lck.Status == "Stock" ? "Ready" : "Retired")
                                    </span>
                                </td>
                                <td class="text-center fw-bold bg-light border-start">@lck.Keys.Count</td>
                                <td class="text-center">@lck.Keys.Count(k => k.Status == "Issued")</td>
                                <td class="text-center">@lck.Keys.Count(k => k.Status == "In Stock")</td>
                                <td class="text-center">@lck.Keys.Count(k => k.Status == "Damaged")</td>
                                <td class="text-center pe-3 fw-bold @(lck.Keys.Any(k => k.Status == "Lost") ? "text-danger" : "")">
                                    @lck.Keys.Count(k => k.Status == "Lost")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    private List<HardwareLock> SpareLocks = new();
    private bool GroupByFormFactor = true;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        // Grab any lock that isn't actively installed, and MAKE SURE TO INCLUDE KEYS
        SpareLocks = await context.Locks
            .Include(l => l.FormFactor)
            .Include(l => l.Keys) // <-- This pulls the key data into memory
            .Where(l => l.IsActive && (l.Status == "Stock" || l.Status == "Retired"))
            .ToListAsync();
    }
}