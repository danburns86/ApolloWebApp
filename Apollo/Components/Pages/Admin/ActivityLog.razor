@page "/admin/activity"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db

<PageTitle>System Activity Log</PageTitle>

<div class="mb-4">
    <h3><i class="bi bi-clock-history me-2"></i>System Activity Log</h3>
    <p class="text-muted">Track all inventory movements and security authorizations.</p>
</div>

<div class="card shadow-sm mb-4 border-primary">
    <div class="card-body bg-light">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold">Time Range</label>
                <select class="form-select" @bind="TimeRange" @bind:after="LoadData">
                    <option value="12h">Last 12 Hours</option>
                    <option value="24h">Last 24 Hours</option>
                    <option value="7d">Last 7 Days</option>
                    <option value="28d">Last 28 Days</option>
                    <option value="custom">-- Custom Range --</option>
                </select>
            </div>
            
            @if (TimeRange == "custom")
            {
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Start</label>
                    <input type="date" class="form-control" @bind="CustomStart" @bind:after="LoadData" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">End</label>
                    <input type="date" class="form-control" @bind="CustomEnd" @bind:after="LoadData" />
                </div>
            }

            <div class="col-md-3">
                <label class="form-label small fw-bold">Filter Staff/User</label>
                <input type="text" class="form-control" placeholder="Search staff name..." @bind="UserFilter" @bind:event="oninput" @onkeyup="LoadData" />
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0 table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark small text-uppercase">
                <tr>
                    <th class="ps-3">Timestamp</th>
                    <th>Action</th>
                    <th>Item</th>
                    <th>Issued To</th>
                    <th>Authorized By</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Logs)
                {
                    <tr>
                        <td class="ps-3 small text-muted">@log.Time.ToString("dd/MM HH:mm:ss")</td>
                        <td><span class="badge @log.BadgeClass">@log.Action</span></td>
                        <td><div class="fw-bold">@log.ItemName</div></td>
                        <td class="fw-bold text-primary">@log.Person</td>
                        <td class="small"><i class="bi bi-person-badge me-1"></i> @(log.AuthorizedBy ?? "System")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private string TimeRange = "24h";
    private DateTime CustomStart = DateTime.Today.AddDays(-7);
    private DateTime CustomEnd = DateTime.Today;
    private string UserFilter = "";

    public class ActivityDto
    {
        public DateTime Time { get; set; }
        public string Action { get; set; } = "";
        public string ItemName { get; set; } = "";
        public string Person { get; set; } = "";
        public string? AuthorizedBy { get; set; }
        public string BadgeClass { get; set; } = "bg-secondary";
    }

    private List<ActivityDto> Logs = new();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var query = Db.CheckoutTransactions
            .Include(t => t.Bunch)
            .Include(t => t.KeyRecord).ThenInclude(k => k!.Lock)
            .AsQueryable();

        // 1. Time Filtering
        DateTime cutoff = TimeRange switch
        {
            "12h" => DateTime.Now.AddHours(-12),
            "24h" => DateTime.Now.AddHours(-24),
            "7d" => DateTime.Now.AddDays(-7),
            "28d" => DateTime.Now.AddDays(-28),
            _ => CustomStart
        };
        
        if (TimeRange == "custom") query = query.Where(t => t.IssueDate >= CustomStart && t.IssueDate <= CustomEnd.AddDays(1));
        else query = query.Where(t => t.IssueDate >= cutoff || (t.ReturnDate != null && t.ReturnDate >= cutoff));

        // 2. User Filtering
        if (!string.IsNullOrWhiteSpace(UserFilter))
            query = query.Where(t => t.IssuedToName.Contains(UserFilter) || t.AuthorizedByUserName!.Contains(UserFilter));

        var txs = await query.OrderByDescending(t => t.IssueDate).ToListAsync();
        Logs.Clear();

        foreach (var t in txs)
        {
            var name = t.Bunch != null ? t.Bunch.Name : (t.KeyRecord != null ? $"{t.KeyRecord.Lock!.LockCode} {t.KeyRecord.SequenceNumber}" : "Unknown");

            Logs.Add(new ActivityDto { Time = t.IssueDate, Action = "ISSUE", ItemName = name, Person = t.IssuedToName, AuthorizedBy = t.AuthorizedByUserName, BadgeClass = "bg-primary" });
            if (t.ReturnDate.HasValue)
                Logs.Add(new ActivityDto { Time = t.ReturnDate.Value, Action = "RETURN", ItemName = name, Person = t.IssuedToName, AuthorizedBy = t.AuthorizedByUserName, BadgeClass = "bg-success" });
        }
        Logs = Logs.OrderByDescending(l => l.Time).ToList();
    }
}