@page "/admin/locations"
@using Apollo.Models
@using Apollo.Data
@using Apollo.Security
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = SystemPermissions.ManageFacilities)]
@inject ILocationService LocationService
@inject IJSRuntime JS

<PageTitle>Facilities & Locations</PageTitle>

<div class="container-fluid py-4">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h1 class="h3 mb-1 text-gray-800">Facilities & Locations</h1>
            <p class="text-muted mb-0">Manage theatre areas, rooms, and safety metadata.</p>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary shadow-sm" @onclick="() => OpenAreaModal()">
                <i class="bi bi-plus-circle me-2"></i>New Area
            </button>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Theatre Areas</h6>
                </div>
                <div class="list-group list-group-flush">
                    @if (areas == null)
                    {
                        <div class="p-3 text-center"><div class="spinner-border spinner-border-sm text-primary"></div></div>
                    }
                    else if (!areas.Any())
                    {
                        <div class="p-4 text-center text-muted italic">No areas defined.</div>
                    }
                    else
                    {
                        @foreach (var area in areas)
                        {
                            <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(selectedArea?.Id == area.Id ? "bg-light border-start border-primary border-4" : "")"
                                 style="cursor: pointer;" @onclick="() => SelectArea(area)">
                                <div class="flex-grow-1">
                                    <div class="fw-bold @(selectedArea?.Id == area.Id ? "text-primary" : "")">@area.Name</div>
                                    <small class="text-muted">@area.Rooms.Count Rooms</small>
                                </div>
                                <button class="btn btn-sm btn-outline-secondary border-0" @onclick:stopPropagation @onclick="() => OpenAreaModal(area)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8 mb-4">
            @if (selectedArea == null)
            {
                <div class="card shadow-sm border-0 bg-light d-flex align-items-center justify-content-center p-5 text-center" style="min-height: 300px;">
                    <div class="opacity-50">
                        <i class="bi bi-arrow-left-circle display-4 mb-3 d-block"></i>
                        <h5>Select an area to manage rooms</h5>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-primary">Rooms in @selectedArea.Name</h6>
                        <button class="btn btn-sm btn-success" @onclick="() => OpenRoomModal()">
                            <i class="bi bi-plus-lg me-1"></i> Add Room
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Room Name</th>
                                        <th>Safety Info</th>
                                        <th>MRBS</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var room in selectedArea.Rooms.OrderBy(r => r.Name))
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-bold">@room.Name</div>
                                                @if (room.IsPublic)
                                                {
                                                    <span class="badge bg-info text-dark" style="font-size: 0.7rem;">Public Snags</span>
                                                }
                                            </td>
                                            <td style="font-size: 0.85rem;">
                                                <div class="mb-1"><strong>Exit:</strong> @(string.IsNullOrEmpty(room.NearestExit) ? "—" : room.NearestExit)</div>
                                                @if (!string.IsNullOrEmpty(room.AlternativeExit))
                                                {
                                                    <div class="text-warning mb-1">
                                                        <strong>If blocked:</strong> @room.AlternativeExit
                                                    </div>
                                                }
                                                <div class="text-muted small">
                                                    <strong>Call Points:</strong><br />
                                                    @((MarkupString)(room.CallPoints?.Replace("\n", "<br />") ?? "None listed"))
                                                </div>
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-light border" @onclick="() => OpenRoomModal(room)"><i class="bi bi-gear"></i></button>
                                                <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteRoom(room)"><i class="bi bi-trash"></i></button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (showAreaModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.6); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <EditForm Model="editingArea" OnValidSubmit="SaveArea">
                    <DataAnnotationsValidator />
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title">@(editingArea.Id == 0 ? "Add New Area" : "Edit Area")</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="() => showAreaModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Area Name</label>
                            <InputText @bind-Value="editingArea.Name" class="form-control" />
                            <ValidationMessage For="@(() => editingArea.Name)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea @bind-Value="editingArea.Description" class="form-control" rows="2" />
                        </div>
                    </div>
                    <div class="modal-footer bg-light">
                        @if (editingArea.Id != 0)
                        {
                            <button type="button" class="btn btn-outline-danger me-auto" @onclick="DeleteArea">Delete Area</button>
                        }
                        <button type="button" class="btn btn-secondary" @onclick="() => showAreaModal = false">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (showRoomModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.6); z-index: 1050;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <EditForm Model="editingRoom" OnValidSubmit="SaveRoom">
                    <DataAnnotationsValidator />
                    <div class="modal-header bg-dark text-white">
                        <h5 class="modal-title">Room: @(editingRoom.Id == 0 ? "New Room" : editingRoom.Name)</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="() => showRoomModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-7 border-end">
                                <h6 class="fw-bold mb-3">General Details</h6>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Room Name</label>
                                    <InputText @bind-Value="editingRoom.Name" class="form-control" />
                                    <ValidationMessage For="@(() => editingRoom.Name)" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">MRBS Room ID</label>
                                    <InputNumber @bind-Value="editingRoom.MRBSRoomId" class="form-control" />
                                </div>
                                <div class="form-check form-switch mt-3">
                                    <InputCheckbox @bind-Value="editingRoom.IsPublic" class="form-check-input" id="isPub" />
                                    <label class="form-check-label fw-bold" for="isPub">Allow Public Snags</label>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <h6 class="fw-bold mb-3 text-danger"><i class="bi bi-shield-exclamation me-1"></i>Fire & Safety</h6>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Primary Escape Route</label>
                                    <InputTextArea @bind-Value="editingRoom.NearestExit" class="form-control" rows="2" placeholder="Primary exit route..." />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold text-warning">If this route is blocked:</label>
                                    <InputTextArea @bind-Value="editingRoom.AlternativeExit" class="form-control" rows="2" placeholder="Alternative exit route..." />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Call Points (List in order)</label>
                                    <InputTextArea @bind-Value="editingRoom.CallPoints" class="form-control" rows="2" placeholder="1. By door&#10;2. In lobby" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Additional Safety Notes</label>
                                    <InputTextArea @bind-Value="editingRoom.FireActionNotes" class="form-control" rows="2" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary" @onclick="() => showRoomModal = false">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4">Save Room</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<Area>? areas;
    private Area? selectedArea;
    private Area editingArea = new();
    private Room editingRoom = new();
    private bool showAreaModal = false;
    private bool showRoomModal = false;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        areas = await LocationService.GetAreasWithRoomsAsync();
        if (selectedArea != null && areas != null)
        {
            selectedArea = areas.FirstOrDefault(a => a.Id == selectedArea.Id);
        }
    }

    private void SelectArea(Area area) => selectedArea = area;

    private void OpenAreaModal(Area? area = null)
    {
        editingArea = area == null ? new Area() : new Area { Id = area.Id, Name = area.Name, Description = area.Description };
        showAreaModal = true;
    }

    private async Task SaveArea()
    {
        await LocationService.UpsertAreaAsync(editingArea);
        showAreaModal = false;
        await LoadData();
    }

    private async Task DeleteArea()
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Delete Area '{editingArea.Name}'?"))
        {
            await LocationService.DeleteAreaAsync(editingArea.Id);
            selectedArea = null;
            showAreaModal = false;
            await LoadData();
        }
    }

    private void OpenRoomModal(Room? room = null)
    {
        if (room == null)
        {
            editingRoom = new Room { AreaId = selectedArea?.Id ?? 0, IsActive = true, IsPublic = true };
        }
        else
        {
            editingRoom = new Room
            {
                Id = room.Id,
                Name = room.Name,
                AreaId = room.AreaId,
                NearestExit = room.NearestExit,
                AlternativeExit = room.AlternativeExit,
                CallPoints = room.CallPoints,
                FireActionNotes = room.FireActionNotes,
                MRBSRoomId = room.MRBSRoomId,
                IsPublic = room.IsPublic,
                IsActive = room.IsActive
            };
        }
        showRoomModal = true;
    }

    private async Task SaveRoom()
    {
        await LocationService.UpsertRoomAsync(editingRoom);
        showRoomModal = false;
        await LoadData();
    }

    private async Task DeleteRoom(Room room)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Delete room '{room.Name}'?"))
        {
            await LocationService.DeleteRoomAsync(room.Id);
            await LoadData();
        }
    }
}