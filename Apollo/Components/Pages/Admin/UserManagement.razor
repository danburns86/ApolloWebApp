@page "/admin/users"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]

<PageTitle>User Management</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>User Management</h2>
        <p class="text-muted mb-0">Manage staff access, roles, and login identities.</p>
    </div>
    <button class="btn btn-primary" @onclick="PrepareCreate">
        <i class="bi bi-person-plus-fill me-1"></i> Add New User
    </button>
</div>
<hr />

<div class="card shadow-sm">
    <div class="card-body p-0 table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">Username</th>
                    <th>Full Name</th>
                    <th>Roles</th>
                    <th class="text-end pe-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Users)
                {
                    <tr>
                        <td class="ps-3 fw-bold">@user.UserName</td>
                        <td>@user.FirstName @user.LastName</td>
                        <td>
                            @if (UserRoles.ContainsKey(user.Id))
                            {
                                @foreach (var role in UserRoles[user.Id])
                                {
                                    <span class="badge bg-info text-dark me-1">@role</span>
                                }
                            }
                        </td>
                        <td class="text-end pe-3">
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => PrepareEdit(user)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(user)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (ShowEditModal && SelectedUser != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">@(IsNewUser ? "Create New User" : $"Edit User: {SelectedUser.UserName}")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => ShowEditModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Username (Login ID)</label>
                        <input type="text" class="form-control" @bind="SelectedUser.UserName" />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small">First Name</label>
                            <input type="text" class="form-control" @bind="SelectedUser.FirstName" />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold small">Last Name</label>
                            <input type="text" class="form-control" @bind="SelectedUser.LastName" />
                        </div>
                    </div>
                    @if (IsNewUser)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Temporary Password</label>
                            <input type="text" class="form-control" @bind="NewUserPassword" />
                        </div>
                    }
                    
                    <hr />
                    <label class="form-label fw-bold small">System Roles</label>
                    <div class="p-2 border rounded bg-light">
                        @foreach (var role in AllRoles)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="role-@role"
                                       checked="@SelectedRoles.Contains(role)"
                                       @onchange="@(e => ToggleRole(role, e.Value))">
                                    <label class="form-check-label" for="role-@role">@role</label>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => ShowEditModal = false">Cancel</button>
                        <button class="btn btn-primary" @onclick="SaveUser">Save Changes</button>
                    </div>
                </div>
            </div>
        </div>
    }

@code {
    private List<ApplicationUser> Users = new();
    private List<string> AllRoles = new();
    private Dictionary<string, IList<string>> UserRoles = new();
    
    private bool ShowEditModal = false;
    private bool IsNewUser = false;
    private ApplicationUser? SelectedUser;
    private List<string> SelectedRoles = new();
    private string NewUserPassword = "Password123!";

    protected override async Task OnInitializedAsync()
    {
        AllRoles = await RoleManager.Roles.Select(r => r.Name!).ToListAsync();
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        Users = await UserManager.Users.OrderBy(u => u.UserName).ToListAsync();
        UserRoles.Clear();
        foreach (var user in Users)
        {
            UserRoles[user.Id] = await UserManager.GetRolesAsync(user);
        }
    }

    private void PrepareCreate()
    {
        SelectedUser = new ApplicationUser { EmailConfirmed = true };
        SelectedRoles = new List<string>();
        IsNewUser = true;
        ShowEditModal = true;
    }

    private async Task PrepareEdit(ApplicationUser user)
    {
        SelectedUser = user;
        SelectedRoles = (await UserManager.GetRolesAsync(user)).ToList();
        IsNewUser = false;
        ShowEditModal = true;
    }

    private void ToggleRole(string role, object? isChecked)
    {
        if ((bool)(isChecked ?? false)) { if (!SelectedRoles.Contains(role)) SelectedRoles.Add(role); }
        else { SelectedRoles.Remove(role); }
    }

    private async Task SaveUser()
    {
        if (SelectedUser == null) return;

        IdentityResult result;
        if (IsNewUser)
        {
            SelectedUser.Email = SelectedUser.UserName; // Fallback
            result = await UserManager.CreateAsync(SelectedUser, NewUserPassword);
        }
        else
        {
            result = await UserManager.UpdateAsync(SelectedUser);
        }

        if (result.Succeeded)
        {
            // Sync Roles
            var currentRoles = await UserManager.GetRolesAsync(SelectedUser);
            await UserManager.AddToRolesAsync(SelectedUser, SelectedRoles.Except(currentRoles));
            await UserManager.RemoveFromRolesAsync(SelectedUser, currentRoles.Except(SelectedRoles));

            ShowEditModal = false;
            await LoadUsers();
        }
    }

    private async Task DeleteUser(ApplicationUser user)
    {
        if (user.UserName?.ToLower() == "admin@apollo.local") return; // Protect primary admin
        await UserManager.DeleteAsync(user);
        await LoadUsers();
    }
}