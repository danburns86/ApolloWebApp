@page "/admin"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]
@rendermode InteractiveServer

<PageTitle>Admin Dashboard</PageTitle>

<div class="container-fluid px-4">
    <div class="mb-4">
        <h2 class="fw-bold">Administrator Dashboard</h2>
        <p class="text-muted">Manage system settings, users, and core lookup data.</p>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-dark text-white h-100">
                <div class="card-body">
                    <h6 class="text-uppercase small opacity-75">Total Inventory</h6>
                    <h2 class="display-6 fw-bold">@TotalKeys</h2>
                    <div class="small"><i class="bi bi-key-fill me-1"></i> Individual Keys</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body">
                    <h6 class="text-uppercase small opacity-75">Currently Issued</h6>
                    <h2 class="display-6 fw-bold">@IssuedCount</h2>
                    <div class="small"><i class="bi bi-person-check me-1"></i> Active Checkouts</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-dark h-100">
                <div class="card-body">
                    <h6 class="text-uppercase small fw-bold opacity-75">Stale Items</h6>
                    <h2 class="display-6 fw-bold">@StaleKeyCount</h2>
                    <div class="small"><i class="bi bi-clock-history me-1"></i> Over 48 Hours</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-danger text-white h-100">
                <div class="card-body">
                    <h6 class="text-uppercase small opacity-75">Security Risks</h6>
                    <h2 class="display-6 fw-bold">@LostCount</h2>
                    <div class="small"><i class="bi bi-exclamation-triangle me-1"></i> Lost/Missing</div>
                </div>
            </div>
        </div>
    </div>

    @if (Config == null)
    {
        <div class="text-center"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="row g-4">
            
            <div class="col-lg-3">
                <div class="card h-100 border-0 shadow-sm border-top border-primary border-4 @(Config.IsKeyManagementEnabled ? "" : "opacity-50 bg-light")">
                    @if (!Config.IsKeyManagementEnabled)
                    {
                        <div class="bg-danger text-white text-center py-1 fw-bold small rounded-bottom mb-2">DISABLED GLOBALLY</div>
                    }
                    <div class="card-header bg-transparent py-3 border-bottom">
                        <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-tools me-2"></i>Key Setup</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <a href="/locks" class="list-group-item list-group-item-action border-0 px-0 @(Config.IsKeyManagementEnabled ? "" : "disabled")">
                                <i class="bi bi-chevron-right me-2 text-primary small"></i> Lock Registry
                            </a>
                            <a href="/setup/formfactors" class="list-group-item list-group-item-action border-0 px-0 @(Config.IsKeyManagementEnabled ? "" : "disabled")">
                                <i class="bi bi-chevron-right me-2 text-primary small"></i> Form Factors
                            </a>
                            <a href="/setup/suppliers" class="list-group-item list-group-item-action border-0 px-0 @(Config.IsKeyManagementEnabled ? "" : "disabled")">
                                <i class="bi bi-chevron-right me-2 text-primary small"></i> Suppliers
                            </a>
                            <a href="/setup/signatories" class="list-group-item list-group-item-action border-0 px-0 @(Config.IsKeyManagementEnabled ? "" : "disabled")">
                                <i class="bi bi-chevron-right me-2 text-primary small"></i> Signatories
                            </a>
                            <a href="/setup/departments" class="list-group-item list-group-item-action border-0 px-0 @(Config.IsKeyManagementEnabled ? "" : "disabled")">
                                <i class="bi bi-chevron-right me-2 text-primary small"></i> Departments
                            </a>
                            <a href="/setup/locations" class="list-group-item list-group-item-action border-0 px-0 @(Config.IsKeyManagementEnabled ? "" : "disabled")">
                                <i class="bi bi-chevron-right me-2 text-primary small"></i> Storage Locations
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="card h-100 border-0 shadow-sm border-top border-success border-4">
                    <div class="card-header bg-white py-3 border-bottom">
                        <h5 class="mb-0 fw-bold text-success"><i class="bi bi-people-fill me-2"></i>User Admin</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <a href="/admin/users" class="list-group-item list-group-item-action border-0 px-0">
                                <i class="bi bi-chevron-right me-2 text-success small"></i> Manage User Accounts
                            </a>
                            <a href="/admin/roles/matrix" class="list-group-item list-group-item-action border-0 px-0">
                                <i class="bi bi-chevron-right me-2 text-success small"></i> Role Permission Matrix
                            </a>
                            <a href="/admin/users/create" class="list-group-item list-group-item-action border-0 px-0 mt-3 text-muted small">
                                <i class="bi bi-person-plus me-1"></i> Register New Staff
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="card h-100 border-0 shadow-sm border-top border-dark border-4 @(Config.IsReportsEnabled ? "" : "opacity-50 bg-light")">
                    @if (!Config.IsReportsEnabled)
                    {
                        <div class="bg-danger text-white text-center py-1 fw-bold small rounded-bottom mb-2">DISABLED GLOBALLY</div>
                    }
                    <div class="card-header bg-transparent py-3 border-bottom">
                        <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-shield-check me-2"></i>Audit & Compliance</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <a href="/admin/reports/audit-logs" class="list-group-item list-group-item-action border-0 px-0 @(Config.IsReportsEnabled ? "" : "disabled")">
                                <i class="bi bi-chevron-right me-2 text-dark small"></i> System Audit Trail
                            </a>
                            <a href="/admin/activity" class="list-group-item list-group-item-action border-0 px-0 @(Config.IsReportsEnabled ? "" : "disabled")">
                                <i class="bi bi-chevron-right me-2 text-dark small"></i> Live Activity Log
                            </a>
                            <a href="/admin/reports/lost-and-found" class="list-group-item list-group-item-action border-0 px-0 text-danger fw-bold @(Config.IsReportsEnabled ? "" : "disabled")">
                                <i class="bi bi-exclamation-triangle me-2"></i> Lost & Found Report
                            </a>
                            <a href="/audit" class="list-group-item list-group-item-action border-0 px-0 mt-2 text-primary @(Config.IsReportsEnabled ? "" : "disabled")">
                                <i class="bi bi-play-circle me-1"></i> Physical Audit Dashboard
                            </a>
                            <a href="/admin/reports/outstanding-audit" class="list-group-item list-group-item-action border-0 px-0 @(Config.IsReportsEnabled ? "" : "disabled")">
                                <i class="bi bi-printer me-2 text-dark small"></i> Printable Sign-off Sheets
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="card h-100 border-0 shadow-sm border-top border-info border-4">
                    <div class="card-header bg-white py-3 border-bottom">
                        <h5 class="mb-0 fw-bold text-info"><i class="bi bi-sliders me-2"></i>System Setup</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <a href="/" class="list-group-item list-group-item-action border-0 px-0 fw-bold">
                                <i class="bi bi-house-door me-2 text-info small"></i> Portal Home Page
                            </a>
                            <a href="/admin/settings/portal" class="list-group-item list-group-item-action border-0 px-0">
                                <i class="bi bi-palette me-2 text-info small"></i> Portal Configuration
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    }
</div>

@code {
    private int TotalKeys;
    private int IssuedCount;
    private int StaleKeyCount;
    private int LostCount;
    private PortalConfiguration? Config;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        Config = await context.PortalConfigurations.FirstOrDefaultAsync();

        if (Config == null) Config = new PortalConfiguration();

        TotalKeys = await context.Keys.CountAsync();
        
        IssuedCount = await context.Keys.CountAsync(k => !string.IsNullOrEmpty(k.IssuedToName))
                    + await context.Bunches.CountAsync(b => !string.IsNullOrEmpty(b.IssuedToName));

        LostCount = await context.Keys.CountAsync(k => k.Status == "Lost")
                  + await context.Bunches.CountAsync(b => b.IsLost);

        var staleThreshold = DateTime.Now.AddHours(-48);
        StaleKeyCount = await context.CheckoutTransactions
            .CountAsync(t => t.ReturnDate == null && t.IssueDate < staleThreshold);
    }
}