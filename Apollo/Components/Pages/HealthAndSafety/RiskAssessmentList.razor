@page "/admin/hs/risk-assessments"
@rendermode InteractiveServer
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Risk Assessments & Fire Audits</PageTitle>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">H&S Compliance Hub</h2>
            <p class="text-muted">Master registry for operational risks and fire safety audits.</p>
        </div>
        <div class="d-flex gap-2">
            @if (selectedIds.Any())
            {
                <div class="btn-group shadow-sm me-2">
                    <button class="btn btn-dark fw-bold" @onclick="PrintBatch">
                        <i class="bi bi-printer me-2"></i>Print Selected (@selectedIds.Count)
                    </button>
                    <button class="btn btn-outline-dark" @onclick="() => selectedIds.Clear()">Clear</button>
                </div>
            }

            <button class="btn btn-outline-primary shadow-sm" @onclick="CreateNewGeneral">
                <i class="bi bi-plus-lg me-1"></i>New General RA
            </button>
    
            <div class="dropdown">
                <button class="btn btn-danger dropdown-toggle shadow-sm" type="button" @onclick="ToggleFireDropdown">
                    <i class="bi bi-fire me-1"></i>New Fire Audit
                </button>
                <ul class="dropdown-menu shadow border-0 p-2 @(showFireDropdown ? "show" : "")"
                    style="min-width: 250px; max-height: 300px; overflow-y: auto; position: absolute; right: 0; z-index: 1050;">
                    <li class="dropdown-header fw-bold text-uppercase small">Select Area to Audit</li>
                    @foreach (var area in allAreas)
                    {
                        <li><button class="dropdown-item rounded small" type="button" @onclick="() => StartFireRA(area.Id)">@area.Name</button></li>
                    }
                </ul>
            </div>
        </div>
    </div>

    @* --- QUICK SELECT BAR --- *@
    <div class="card border-0 shadow-sm mb-4 bg-light">
        <div class="card-body py-2 d-flex gap-3 align-items-center">
            <span class="small fw-bold text-muted text-uppercase">Quick Batch Selection:</span>
            <select class="form-select form-select-sm w-auto" @onchange="SelectByArea">
                <option value="">-- Select by Area --</option>
                @foreach (var area in allAreas)
                {
                    <option value="@area.Id">@area.Name</option>
                }
            </select>
            <select class="form-select form-select-sm w-auto" @onchange="SelectByRoom">
                <option value="">-- Select by Room --</option>
                @foreach (var area in allAreas)
                {
                    <optgroup label="@area.Name">
                        @foreach (var room in area.Rooms ?? new List<Room>())
                        {
                            <option value="@room.Id">@room.Name</option>
                        }
                    </optgroup>
                }
            </select>
        </div>
    </div>

    @if (showFireDropdown)
    {
        <div style="position:fixed; top:0; left:0; width:100vw; height:100vh; z-index:1000;" @onclick="ToggleFireDropdown"></div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white small fw-bold">
                    <tr>
                        <th class="ps-4" style="width: 40px;">
                            <input type="checkbox" class="form-check-input"
                                   checked="@(allRAs.Any() && selectedIds.Count == allRAs.Count)"
                                   @onchange="ToggleSelectAll" />
                        </th>
                        <th>Title / Reference</th>
                        <th>Type</th>
                        <th>Scope</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ra in allRAs)
                    {
                        <tr>
                            <td class="ps-4">
                                <input type="checkbox" class="form-check-input"
                                       checked="@selectedIds.Contains(ra.Id)"
                                       @onchange="(e) => ToggleSelection(ra.Id, (bool)e.Value!)" />
                            </td>
                            <td>
                                <div class="fw-bold">@ra.Title</div>
                                <div class="small text-muted">Created @ra.AssessmentDate.ToShortDateString()</div>
                            </td>
                            <td><span class="badge bg-secondary-subtle text-secondary border border-secondary">@ra.Type</span></td>
                            <td>
                                @if (ra.Production != null)
                                {
                                    <span class="small"><i class="bi bi-play-circle me-1"></i>@ra.Production.Title</span>
                                }
                                else if (ra.Area != null)
                                {

                                    <span class="small"><i class="bi bi-geo-alt me-1"></i>@ra.Area.Name</span>
                                }
                                else
                                {

                                    <span class="small text-muted">General Ops</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (!ra.IsApproved)
                                {
                                    <span class="badge bg-secondary">Draft</span>
                                }
                                else if (ra is FireRiskAssessment f && f.ActionPlan.Any(a => !a.IsResolved))
                                {

                                    <span class="badge bg-warning text-dark">Action Required</span>
                                }
                                else
                                {

                                    <span class="badge bg-success">Compliant</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-dark me-1" @onclick="() => HandleNavigation(ra)">Edit</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<RiskAssessment> allRAs = new();
    private List<Area> allAreas = new();
    private List<int> selectedIds = new();
    private bool isLoading = true;
    private bool showFireDropdown = false;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        using var context = await DbFactory.CreateDbContextAsync();
        
        allRAs = await context.RiskAssessments
            .Include(r => r.Production)
            .Include(r => r.Area)
            .Include("ActionPlan")
            .OrderByDescending(r => r.AssessmentDate)
            .ToListAsync();

        allAreas = await context.Areas.Include(a => a.Rooms).OrderBy(a => a.Name).ToListAsync();
        isLoading = false;
    }

    private void ToggleFireDropdown() => showFireDropdown = !showFireDropdown;
    private void CreateNewGeneral() => Nav.NavigateTo("/admin/hs/risk-assessments/edit/0");
    private void StartFireRA(int areaId) { showFireDropdown = false; Nav.NavigateTo($"/admin/hs/fire-risk-assessment/new/{areaId}"); }
    
    private void HandleNavigation(RiskAssessment ra)
    {
        if (ra.Type == RiskAssessmentType.Fire) Nav.NavigateTo($"/admin/hs/fire-risk-assessment/edit/{ra.Id}");
        else Nav.NavigateTo($"/admin/hs/risk-assessments/edit/{ra.Id}");
    }

    private void ToggleSelection(int id, bool isSelected)
    {
        if (isSelected) { if (!selectedIds.Contains(id)) selectedIds.Add(id); }
        else { selectedIds.Remove(id); }
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if ((bool)e.Value!) selectedIds = allRAs.Select(r => r.Id).ToList();
        else selectedIds.Clear();
    }

    private void SelectByArea(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int areaId))
        {
            var ids = allRAs.Where(r => r.AreaId == areaId).Select(r => r.Id);
            foreach (var id in ids) { if (!selectedIds.Contains(id)) selectedIds.Add(id); }
        }
    }

    private void SelectByRoom(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int roomId))
        {
            var ids = allRAs.Where(r =>
                (r is FireRiskAssessment f && f.RoomAssignments.Any(a => a.RoomId == roomId))
                || (r.Area != null && r.Area.Rooms.Any(rm => rm.Id == roomId))
            ).Select(r => r.Id);
            foreach (var id in ids) { if (!selectedIds.Contains(id)) selectedIds.Add(id); }
        }
    }

    private void PrintBatch() => Nav.NavigateTo($"/admin/hs/risk-assessments/print-batch?ids={string.Join(",", selectedIds)}");
}