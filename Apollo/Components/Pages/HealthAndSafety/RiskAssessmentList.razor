@page "/admin/hs/risk-assessments"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Risk Assessments & Fire Audits</PageTitle>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">H&S Compliance Hub</h2>
            <p class="text-muted">Master registry for operational risks and fire safety audits.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="CreateNewGeneral">
                <i class="bi bi-plus-lg me-1"></i>New General RA
            </button>
    
            <div class="dropdown">
                <button class="btn btn-danger dropdown-toggle shadow-sm" type="button" @onclick="ToggleFireDropdown">
                    <i class="bi bi-fire me-1"></i>New Fire Audit
                </button>
                <ul class="dropdown-menu shadow border-0 p-2 @(showFireDropdown ? "show" : "")"
                    style="min-width: 250px; max-height: 300px; overflow-y: auto; position: absolute; right: 0; z-index: 1050;">
                    <li class="dropdown-header fw-bold text-uppercase small">Select Area to Audit</li>
                    @foreach (var area in allAreas)
                    {
                        <li><button class="dropdown-item rounded small" type="button" @onclick="() => StartFireRA(area.Id)">@area.Name</button></li>
                    }
                </ul>
            </div>
        </div>
    </div>

    @if (showFireDropdown)
    {
        <div style="position:fixed; top:0; left:0; width:100vw; height:100vh; z-index:1000;" @onclick="ToggleFireDropdown"></div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-dark text-white small fw-bold">
                    <tr>
                        <th class="ps-4">Title / Reference</th>
                        <th>Type</th>
                        <th>Scope</th>
                        <th class="text-center">Compliance Status</th>
                        <th class="text-end pe-4">Next Review</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ra in allRAs)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@ra.Title</div>
                                <div class="small text-muted">Created @ra.AssessmentDate.ToShortDateString()</div>
                            </td>
                            <td><span class="badge bg-secondary-subtle text-secondary border border-secondary">@ra.Type</span></td>
                            <td>
                                @if (ra.Production != null)
                                {
                                    <span class="small"><i class="bi bi-play-circle me-1"></i>@ra.Production.Title</span>
                                }
                                else if (ra.Area != null)
                                {

                                    <span class="small"><i class="bi bi-geo-alt me-1"></i>@ra.Area.Name</span>
                                }
                                else
                                {

                                    <span class="small text-muted">General Ops</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (!ra.IsApproved)
                                {
                                    <span class="badge bg-secondary shadow-sm">Draft</span>
                                }
                                else if (ra is FireRiskAssessment fireRa && fireRa.ActionPlan.Any(a => !a.IsResolved))
                                {
                                    <span class="badge bg-warning text-dark border border-warning shadow-sm">
                                        <i class="bi bi-exclamation-triangle me-1"></i>Action Required
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success shadow-sm">
                                        <i class="bi bi-shield-check me-1"></i>Compliant
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="small @(ra.ReviewDueDate <= DateTime.Today ? "text-danger fw-bold" : "text-muted")">
                                    @ra.ReviewDueDate.ToShortDateString()
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-dark me-1" @onclick="() => HandleNavigation(ra)">
                                    <i class="bi bi-pencil-square me-1"></i>Edit
                                </button>
                                <button class="btn btn-sm btn-light border" title="Export PDF"><i class="bi bi-file-earmark-pdf"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<RiskAssessment> allRAs = new();
    private List<Area> allAreas = new();
    private bool isLoading = true;
    private bool showFireDropdown = false;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        using var context = await DbFactory.CreateDbContextAsync();
        
        // Use string-based include for the polymorphic ActionPlan property
        allRAs = await context.RiskAssessments
            .Include(r => r.Production)
            .Include(r => r.Area)
            .Include("ActionPlan")
            .OrderByDescending(r => r.AssessmentDate)
            .ToListAsync();

        allAreas = await context.Areas.OrderBy(a => a.Name).ToListAsync();
        isLoading = false;
    }

    private void ToggleFireDropdown() => showFireDropdown = !showFireDropdown;
    private void CreateNewGeneral() => Nav.NavigateTo("/admin/hs/risk-assessments/edit/0");
    private void StartFireRA(int areaId) { showFireDropdown = false; Nav.NavigateTo($"/admin/hs/fire-risk-assessment/new/{areaId}"); }
    
    private void CloneForProduction(int prodId) => Nav.NavigateTo($"/admin/hs/risk-assessments/edit/0?prodId={prodId}");

    private void HandleNavigation(RiskAssessment ra)
    {
        if (ra.Type == RiskAssessmentType.Fire) Nav.NavigateTo($"/admin/hs/fire-risk-assessment/edit/{ra.Id}");
        else Nav.NavigateTo($"/admin/hs/risk-assessments/edit/{ra.Id}");
    }
}