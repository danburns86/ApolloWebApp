@page "/admin/hs/risk-assessments"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Risk Assessments</PageTitle>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Risk Assessments</h2>
            <p class="text-muted">Manage operational, production, and fire safety assessments.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="CreateNewGeneral">
                <i class="bi bi-plus-lg me-1"></i>New General RA
            </button>
    
            <div class="dropdown">
                <button class="btn btn-danger dropdown-toggle shadow-sm" type="button" @onclick="ToggleFireDropdown">
                    <i class="bi bi-fire me-1"></i>New Fire RA
                </button>
                <ul class="dropdown-menu shadow border-0 p-2 @(showFireDropdown ? "show" : "")"
                    style="min-width: 250px; max-height: 300px; overflow-y: auto; position: absolute; right: 0; z-index: 1050;">
                    <li class="dropdown-header fw-bold text-uppercase small">Select Area to Audit</li>
                    @foreach (var area in allAreas)
                    {
                        <li><button class="dropdown-item rounded small" type="button" @onclick="() => StartFireRA(area.Id)">@area.Name</button></li>
                    }
                </ul>
            </div>

            <div class="dropdown">
                <button class="btn btn-primary dropdown-toggle shadow-sm" type="button" data-bs-toggle="dropdown">
                    Quick Clone Show RA
                </button>
                <div class="dropdown-menu shadow border-0">
                    @foreach (var prod in upcomingProductions)
                    {
                        <button class="dropdown-item" @onclick="() => CloneForProduction(prod.Id)">@prod.Title</button>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (showFireDropdown)
    {
        <div style="position:fixed; top:0; left:0; width:100vw; height:100vh; z-index:1000;" @onclick="ToggleFireDropdown"></div>
    }

    <div class="card shadow-sm border-0 rounded-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Title</th>
                        <th>Type</th>
                        <th>Scope</th>
                        <th>Status</th>
                        <th>Actions</th>
                        <th class="text-end pe-4">Next Review</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ra in allRAs)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@ra.Title</div>
                                <div class="small text-muted">@ra.AssessmentDate.ToShortDateString()</div>
                            </td>
                            <td><span class="badge bg-secondary">@ra.Type</span></td>
                            <td>
                                @if (ra.Production != null)
                                {
                                    <span class="small">Prod: @ra.Production.Title</span>
                                }
                                else if (ra.Area != null)
                                {

                                    <span class="small">Area: @ra.Area.Name</span>
                                }
                                else
                                {

                                    <span class="small text-muted">General Ops</span>
                                }
                            </td>
                            <td>
                                @if (ra.IsApproved)
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else
                                {

                                    <span class="badge bg-warning text-dark">Draft</span>
                                }
                            </td>
                            <td>
                                @if (ra is FireRiskAssessment fireRa && fireRa.ActionPlan.Any(a => !a.IsCompleted))
                                {
                                    <span class="badge bg-danger">Action Plan Required</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-dark me-2" @onclick="() => HandleNavigation(ra)">Edit</button>
                                <span class="small @(ra.ReviewDueDate <= DateTime.Today ? "text-danger fw-bold" : "")">@ra.ReviewDueDate.ToShortDateString()</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<RiskAssessment> allRAs = new();
    private List<Production> upcomingProductions = new();
    private List<Area> allAreas = new();
    private bool isLoading = true;
    private bool showFireDropdown = false;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        allRAs = await context.RiskAssessments.Include(r => r.Production).Include(r => r.Area).OrderByDescending(r => r.AssessmentDate).ToListAsync();
        upcomingProductions = await context.Productions.Where(p => p.EndDate >= DateTime.Today).OrderBy(p => p.StartDate).ToListAsync();
        allAreas = await context.Areas.OrderBy(a => a.Name).ToListAsync();
        isLoading = false;
    }

    private void ToggleFireDropdown() => showFireDropdown = !showFireDropdown;

    private void StartFireRA(int areaId) { showFireDropdown = false; Nav.NavigateTo($"/admin/hs/fire-risk-assessment/new/{areaId}"); }

    private void CreateNewGeneral() => Nav.NavigateTo("/admin/hs/risk-assessments/edit/0");

    private void CloneForProduction(int prodId) => Nav.NavigateTo($"/admin/hs/risk-assessments/edit/0?prodId={prodId}");

    private void HandleNavigation(RiskAssessment ra)
    {
        if (ra.Type == RiskAssessmentType.Fire) Nav.NavigateTo($"/admin/hs/fire-risk-assessment/edit/{ra.Id}");
        else Nav.NavigateTo($"/admin/hs/risk-assessments/edit/{ra.Id}");
    }
}