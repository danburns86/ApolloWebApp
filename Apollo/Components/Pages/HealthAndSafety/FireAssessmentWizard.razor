@page "/admin/hs/fire-risk-assessment/new/{areaId:int}"
@page "/admin/hs/fire-risk-assessment/edit/{raId:int}"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

<div class="container py-4 max-w-6xl">
    @* --- STATUS HEADER --- *@
    <div class="card border-0 shadow-sm mb-4 @(fsra.IsApproved ? "bg-success text-white" : "bg-warning text-dark")">
        <div class="card-body d-flex justify-content-between align-items-center py-3">
            <div>
                <h4 class="fw-bold mb-0">
                    <i class="bi @(fsra.IsApproved ? "bi-shield-check" : "bi-pencil-square") me-2"></i>
                    @(fsra.IsApproved ? "Audit Sealed & Approved" : "Audit Draft - Editing Permitted")
                </h4>
                @if (fsra.IsApproved)
                {
                    <p class="small mb-0 opacity-75">Signed off by @fsra.ApprovedBy on @fsra.AssessmentDate.ToShortDateString()</p>
                }
            </div>
            <div class="d-flex gap-2">
                @if (!fsra.IsApproved)
                {
                    <button class="btn btn-dark fw-bold px-4 shadow-sm" @onclick="SignOffAudit">
                        <i class="bi bi-vector-pen me-2"></i>Sign Off & Seal
                    </button>
                }
                else
                {
                    <button class="btn btn-outline-light btn-sm" @onclick="() => fsra.IsApproved = false">Revoke Seal (Admin Only)</button>
                }
                <button class="btn btn-primary fw-bold px-4 shadow-sm" @onclick="SaveFSRA"><i class="bi bi-save me-2"></i>Save Progress</button>
            </div>
        </div>
    </div>

    @* --- STEP 1 & 2: IDENTIFICATION (LOCKED IF APPROVED) --- *@
    <fieldset disabled="@fsra.IsApproved">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-dark text-white fw-bold">Steps 1 & 2: Identify Hazards & People</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="small fw-bold">Sources of Ignition</label>
                        <textarea class="form-control" rows="3" @bind="fsra.Narrative_IgnitionSources"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="small fw-bold">Sources of Fuel</label>
                        <textarea class="form-control" rows="3" @bind="fsra.Narrative_FuelSources"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="small fw-bold">People at Risk</label>
                        <textarea class="form-control" rows="2" @bind="fsra.Narrative_PeopleAtRisk"></textarea>
                    </div>
                </div>
            </div>
        </div>

        @* --- STEP 3: CHECKLIST (LOCKED IF APPROVED) --- *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-danger text-white fw-bold">Step 3: Evaluate & Act</div>
            <div class="card-body p-0">
                <table class="table align-middle mb-0">
                    <thead class="bg-light small fw-bold">
                        <tr><th class="ps-4">Control Point</th><th class="text-center" style="width:140px;">Response</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        <tr class="table-secondary"><td colspan="3" class="ps-4 fw-bold small">ELECTRICAL & FIRE LOAD</td></tr>
                        @renderRow("Fixed installations inspected (5yr)?", () => fsra.Q_Elec_FixedInspected, (v) => fsra.Q_Elec_FixedInspected = v)
                        @renderRow("Appliances PAT tested?", () => fsra.Q_Elec_ApplianceTested, (v) => fsra.Q_Elec_ApplianceTested = v)
                        @renderRow("Waste/Bins stored away from building?", () => fsra.Q_Arson_WasteSafe, (v) => fsra.Q_Arson_WasteSafe = v)
                        
                        <tr class="table-secondary"><td colspan="3" class="ps-4 fw-bold small">ESCAPE & WARNING</td></tr>
                        @renderRow("Escape routes clear & functional?", () => fsra.Q_Escape_Obstructions, (v) => fsra.Q_Escape_Obstructions = v)
                        @renderRow("Alarm system coverage adequate?", () => fsra.Q_Warning_AlarmSuitable, (v) => fsra.Q_Warning_AlarmSuitable = v)
                        @renderRow("Emergency lighting standard adequate?", () => fsra.Q_Warning_DetectorsAdequate, (v) => fsra.Q_Warning_DetectorsAdequate = v)
                    </tbody>
                </table>
            </div>
        </div>
    </fieldset>

    @* --- STEP 4: LIVING ACTION PLAN (ALWAYS EDITABLE) --- *@
    <div class="card border-0 shadow-sm mb-4 border-start border-4 border-warning">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-warning">Step 4: Record & Remediate (Living Action Plan)</h6>
            <span class="badge bg-warning text-dark">@fsra.ActionPlan.Count(a => !a.IsResolved) Outstanding</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead class="bg-light small fw-bold">
                        <tr>
                            <th class="ps-3">Deficiency Item</th>
                            <th>Proposed Rectification</th>
                            <th>Timescale</th>
                            <th>Resolved?</th>
                            <th>Resolution Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in fsra.ActionPlan)
                        {
                            <tr class="@(item.IsResolved ? "table-success opacity-75" : "")">
                                <td class="ps-3 fw-bold small">@item.ItemName</td>
                                <td><input type="text" class="form-control form-control-sm border-0" @bind="item.ProposedAction" disabled="@fsra.IsApproved" /></td>
                                <td><input type="text" class="form-control form-control-sm border-0" @bind="item.Timescale" disabled="@fsra.IsApproved" /></td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-inline-block">
                                        <input class="form-check-input" type="checkbox" checked="@item.IsResolved" @onchange="(e) => ToggleResolve(item, (bool)e.Value!)" />
                                    </div>
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" @bind="item.ResolutionNotes"
                                           placeholder="@(item.IsResolved ? $"Fixed by {item.ResolvedBy} on {item.ResolvedDate?.ToShortDateString()}" : "Enter notes here...")" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int areaId { get; set; }
    [Parameter] public int raId { get; set; }
    private Area? targetArea;
    private FireRiskAssessment fsra = new() { Type = RiskAssessmentType.Fire, AssessmentDate = DateTime.Now };

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        if (raId != 0)
        {
            fsra = await context.FireRiskAssessments.Include(f => f.ActionPlan).Include(f => f.RoomAssignments).ThenInclude(a => a.Room).FirstAsync(f => f.Id == raId);
            targetArea = await context.Areas.FindAsync(fsra.AreaId);
        }
        else
        {
            targetArea = await context.Areas.Include(a => a.Rooms).FirstOrDefaultAsync(a => a.Id == areaId);
            fsra.AreaId = areaId; fsra.Title = $"Fire Audit: {targetArea?.Name}";
            if (targetArea?.Rooms != null)
            {
                foreach (var r in targetArea.Rooms) fsra.RoomAssignments.Add(new RoomFireSafetyAssignment { RoomId = r.Id, Room = r });
            }
        }
    }

    RenderFragment renderRow(string label, Func<bool> getter, Action<bool> setter) => __builder =>
    {
        <tr>
            <td class="ps-4 small">@label</td>
            <td class="text-center">
                <div class="btn-group btn-group-sm">
                    <button class="btn @(getter() ? "btn-success" : "btn-outline-secondary")" @onclick="() => { setter(true); ClearAction(label); }">YES</button>
                    <button class="btn @(!getter() ? "btn-danger" : "btn-outline-secondary")" @onclick="() => { setter(false); TriggerAction(label); }">NO</button>
                </div>
            </td>
            <td>
                @if (!getter())
                {
                    <span class="text-danger small fw-bold"><i class="bi bi-exclamation-triangle"></i> OPEN ACTION</span>
                }
                else
                {

                    <span class="text-muted tiny">Compliant</span>
                }
            </td>
        </tr>
    };

    private void TriggerAction(string name) { if (!fsra.ActionPlan.Any(a => a.ItemName == name)) fsra.ActionPlan.Add(new FireActionPlanItem { ItemName = name }); }
    private void ClearAction(string name) => fsra.ActionPlan.RemoveAll(a => a.ItemName == name);

    private void ToggleResolve(FireActionPlanItem item, bool isResolved)
    {
        item.IsResolved = isResolved;
        if (isResolved) { item.ResolvedDate = DateTime.Now; item.ResolvedBy = "Technical Manager"; }
        else { item.ResolvedDate = null; item.ResolvedBy = null; }
    }

    private async Task SignOffAudit()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        fsra.IsApproved = true;
        fsra.ApprovedBy = authState.User.Identity?.Name ?? "Admin";
        await SaveFSRA();
    }

    private async Task SaveFSRA()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        // Detach navigation properties to prevent Identity Insert errors
        fsra.Area = null;
        foreach (var a in fsra.RoomAssignments) a.Room = null;

        if (fsra.Id == 0) context.FireRiskAssessments.Add(fsra);
        else context.FireRiskAssessments.Update(fsra);
        
        await context.SaveChangesAsync();
        Nav.NavigateTo("/admin/hs/risk-assessments");
    }
}