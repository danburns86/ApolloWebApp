@page "/admin/hs/fire-risk-assessment/new/{areaId:int}"
@page "/admin/hs/fire-risk-assessment/edit/{raId:int}"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<div class="container py-4 max-w-6xl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold"><i class="bi bi-fire text-danger me-2"></i>Fire Safety Audit</h2>
            <p class="text-muted">Premises Area: <strong>@targetArea?.Name</strong></p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary fw-bold" @onclick='() => Nav.NavigateTo("/admin/hs/risk-assessments")'>Cancel</button>
            <button class="btn btn-primary fw-bold px-4 shadow" @onclick="SaveFSRA"><i class="bi bi-save me-2"></i>Save Audit</button>
        </div>
    </div>

    @* --- STEP 1: PREMISES --- *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-dark text-white fw-bold">Step 1: Premises Info</div>
        <div class="card-body bg-light">
            <div class="row g-3">
                <div class="col-md-6"><label class="small fw-bold">Construction</label><input type="text" class="form-control" @bind="fsra.ConstructionDetails" placeholder="e.g. Brick/Concrete with timber stage" /></div>
                <div class="col-md-3"><label class="small fw-bold">Floors</label><input type="number" class="form-control" @bind="fsra.NumberOfFloors" /></div>
                <div class="col-md-3"><label class="small fw-bold">Max Occupancy</label><input type="number" class="form-control" @bind="fsra.MaxOccupancy" /></div>
            </div>
        </div>
    </div>

    @* --- NEW SECTION: STEPS 1 & 2 NARRATIVE --- *@
    <div class="card border-0 shadow-sm mb-4 border-start border-4 border-danger">
        <div class="card-header bg-white fw-bold text-danger">Steps 1 & 2: Identify Hazards & People at Risk</div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-6">
                    <label class="small fw-bold text-uppercase text-muted">Step 1a: Sources of Ignition</label>
                    <textarea class="form-control mt-1" rows="3" @bind="fsra.Narrative_IgnitionSources"
                              placeholder="Identify heaters, lighting, electrical equipment, hot works, smoking areas, etc."></textarea>
                </div>
                <div class="col-md-6">
                    <label class="small fw-bold text-uppercase text-muted">Step 1b: Sources of Fuel</label>
                    <textarea class="form-control mt-1" rows="3" @bind="fsra.Narrative_FuelSources"
                              placeholder="Identify anything that could burn: scenery, costumes, prop storage, waste bins, chemicals."></textarea>
                </div>
                <div class="col-12">
                    <label class="small fw-bold text-uppercase text-muted">Step 2: People at Risk</label>
                    <textarea class="form-control mt-1" rows="2" @bind="fsra.Narrative_PeopleAtRisk"
                              placeholder="Note anyone especially at risk: night staff, lone workers, visitors, elderly, children, or disabled persons."></textarea>
                </div>
            </div>
        </div>
    </div>

    @* --- STEP 3: THE GOV CHECKLIST --- *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-danger text-white fw-bold">Step 3: Evaluate & Act (Checklist)</div>
        <div class="card-body p-0">
            <table class="table align-middle mb-0">
                <thead class="bg-light small fw-bold">
                    <tr><th class="ps-4">Control Point</th><th style="width: 140px;" class="text-center">Response</th><th>Compliance Status</th></tr>
                </thead>
                <tbody>
                    <tr class="table-secondary"><td colspan="3" class="ps-4 fw-bold small">ELECTRICAL & HEATING</td></tr>
                    @renderRow("Fixed installations inspected (5yr)?", () => fsra.Q_Elec_FixedInspected, (v) => fsra.Q_Elec_FixedInspected = v)
                    @renderRow("Appliances PAT tested?", () => fsra.Q_Elec_ApplianceTested, (v) => fsra.Q_Elec_ApplianceTested = v)
                    @renderRow("Trailing leads/adaptors avoided?", () => fsra.Q_Elec_NoAdapters, (v) => fsra.Q_Elec_NoAdapters = v)
                    
                    <tr class="table-secondary"><td colspan="3" class="ps-4 fw-bold small">SMOKING, ARSON & SUBSTANCES</td></tr>
                    @renderRow("Adequate measures to stop smoking inside?", () => fsra.Q_Smoke_MeasuresInPlace, (v) => fsra.Q_Smoke_MeasuresInPlace = v)
                    @renderRow("Premises adequately secured against arson?", () => fsra.Q_Arson_Secure, (v) => fsra.Q_Arson_Secure = v)
                    @renderRow("Dangerous substances safely managed?", () => fsra.Q_Arson_WasteSafe, (v) => fsra.Q_Arson_WasteSafe = v)

                    <tr class="table-secondary"><td colspan="3" class="ps-4 fw-bold small">ESCAPE & WARNING</td></tr>
                    @renderRow("Escape routes clear of obstructions?", () => fsra.Q_Escape_Obstructions, (v) => fsra.Q_Escape_Obstructions = v)
                    @renderRow("All fire exits easily openable?", () => fsra.Q_Escape_ExitsOpenable, (v) => fsra.Q_Escape_ExitsOpenable = v)
                    @renderRow("Fire alarm system coverage adequate?", () => fsra.Q_Warning_AlarmSuitable, (v) => fsra.Q_Warning_AlarmSuitable = v)
                    @renderRow("Emergency lighting standard adequate?", () => fsra.Q_Warning_DetectorsAdequate, (v) => fsra.Q_Warning_DetectorsAdequate = v)

                    <tr class="table-secondary"><td colspan="3" class="ps-4 fw-bold small">MANAGEMENT & TRAINING</td></tr>
                    @renderRow("Staff trained on fire plan & drills done?", () => fsra.Q_Manage_Training, (v) => fsra.Q_Manage_Training = v)
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-light p-3">
            <label class="small fw-bold text-muted">Step 3 Summary: Evaluation Notes</label>
            <textarea class="form-control mt-1" rows="3" @bind="fsra.Narrative_EvaluationNotes"
                      placeholder="Overall evaluation of the risk to people. Record how you have reduced or removed risks identified above."></textarea>
        </div>
    </div>

    @* --- STEP 4: ACTION PLAN --- *@
    @if (fsra.ActionPlan.Any())
    {
        <div class="card border-0 shadow-sm mb-4 border-start border-4 border-warning">
            <div class="card-header bg-white fw-bold text-warning">Step 4: Record & Plan (Outstanding Actions)</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="small fw-bold"><tr><th class="ps-3">Deficiency Item</th><th>Proposed Rectification</th><th>Timescale</th><th>Responsible</th></tr></thead>
                    <tbody>
                        @foreach (var item in fsra.ActionPlan)
                        {
                            <tr>
                                <td class="ps-3 fw-bold small text-danger">@item.ItemName</td>
                                <td><input type="text" class="form-control form-control-sm" @bind="item.ProposedAction" /></td>
                                <td><input type="text" class="form-control form-control-sm" @bind="item.Timescale" /></td>
                                <td><input type="text" class="form-control form-control-sm" @bind="item.PersonResponsible" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* --- ROOM ASSIGNMENTS --- *@
    <div class="card border-0 shadow-sm mb-5">
        <div class="card-header bg-info text-white fw-bold">Room Coverage Inherited from this Area Audit</div>
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead class="small fw-bold"><tr><th class="ps-4">Room</th><th class="text-center">Included?</th><th>Exception Detail</th></tr></thead>
                <tbody>
                    @foreach (var ass in fsra.RoomAssignments)
                    {
                        <tr>
                            <td class="ps-4">@ass.Room?.Name</td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input" type="checkbox" @bind="ass.IsCoveredByAreaAssessment" />
                                </div>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm" @bind="ass.ExceptionNote"
                                       disabled="@ass.IsCoveredByAreaAssessment" placeholder="Note if this room needs a separate deep-dive" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Parameter] public int areaId { get; set; }
    [Parameter] public int raId { get; set; }
    private Area? targetArea;
    private FireRiskAssessment fsra = new() { Type = RiskAssessmentType.Fire, AssessmentDate = DateTime.Now, ReviewDueDate = DateTime.Today.AddYears(1) };

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        if (raId != 0)
        {
            fsra = await context.FireRiskAssessments.Include(f => f.ActionPlan).Include(f => f.RoomAssignments).ThenInclude(a => a.Room).FirstAsync(f => f.Id == raId);
            targetArea = await context.Areas.FindAsync(fsra.AreaId);
        }
        else
        {
            targetArea = await context.Areas.Include(a => a.Rooms).FirstOrDefaultAsync(a => a.Id == areaId);
            fsra.AreaId = areaId;
            fsra.Title = $"Fire Audit: {targetArea?.Name}";
            if (targetArea?.Rooms != null)
            {
                foreach (var r in targetArea.Rooms) fsra.RoomAssignments.Add(new RoomFireSafetyAssignment { RoomId = r.Id, Room = r, IsCoveredByAreaAssessment = true });
            }
        }
    }

    RenderFragment renderRow(string label, Func<bool> getter, Action<bool> setter) => __builder =>
    {
        <tr>
            <td class="ps-4 small">@label</td>
            <td class="text-center">
                <div class="btn-group btn-group-sm shadow-sm">
                    <button class="btn @(getter() ? "btn-success" : "btn-outline-secondary")" @onclick="() => { setter(true); ClearAction(label); }">YES</button>
                    <button class="btn @(!getter() ? "btn-danger" : "btn-outline-secondary")" @onclick="() => { setter(false); TriggerAction(label); }">NO</button>
                </div>
            </td>
            <td>
                @if (!getter())
                {
                    <span class="text-danger small fw-bold"><i class="bi bi-exclamation-triangle"></i> ACTION REQUIRED IN STEP 4</span>
                }
                else
                {

                    <span class="text-muted tiny">Compliant</span>
                }
            </td>
        </tr>
    };

    private void TriggerAction(string name) { if (!fsra.ActionPlan.Any(a => a.ItemName == name)) fsra.ActionPlan.Add(new FireActionPlanItem { ItemName = name }); }
    private void ClearAction(string name) => fsra.ActionPlan.RemoveAll(a => a.ItemName == name);

    private async Task SaveFSRA()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        // 1. If this is a new assessment
        if (fsra.Id == 0)
        {
            fsra.AssessedBy = "Technical Manager";
        
            // IMPORTANT: We must null out the navigation objects so EF doesn't
            // try to re-insert the existing Area or Rooms into the database.
            // The IDs (AreaId and RoomId) are already set, which is all the DB needs.
        
            // Null the Area object on the parent
            var tempAreaId = fsra.AreaId;
            fsra.Area = null;
            fsra.AreaId = tempAreaId;

            // Null the Room objects in the assignments list
            foreach (var assignment in fsra.RoomAssignments)
            {
                assignment.Room = null;
                // The assignment already has RoomId set, so it will link correctly.
            }

            context.FireRiskAssessments.Add(fsra);
        }
        else
        {
            // 2. If editing, we need to handle existing assignments
            // We'll update the main record first
            context.FireRiskAssessments.Update(fsra);
        
            // Ensure child objects aren't treated as 'New'
            foreach (var assignment in fsra.RoomAssignments)
            {
                assignment.Room = null;
                if (assignment.Id == 0) context.RoomFireSafetyAssignments.Add(assignment);
                else context.RoomFireSafetyAssignments.Update(assignment);
            }
        
            foreach (var action in fsra.ActionPlan)
            {
                if (action.Id == 0) context.FireActionPlanItems.Add(action);
                else context.FireActionPlanItems.Update(action);
            }
        }

        try
        {
            await context.SaveChangesAsync();
            Nav.NavigateTo("/admin/hs/risk-assessments");
        }
        catch (Exception ex)
        {
            // Log the error if needed
            Console.WriteLine($"Error saving FSRA: {ex.Message}");
            throw;
        }
    }
}