@page "/admin/hs/risk-assessments/edit/{raId:int}"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<div class="container py-4 max-w-7xl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="/admin/hs/risk-assessments" class="text-decoration-none small text-muted"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
            <h2 class="fw-bold mt-1">@(raId == 0 ? "Generate New Assessment" : "Edit Assessment")</h2>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-success" @onclick="ToggleApproval">
                <i class="bi @(ra.IsApproved ? "bi-unlock" : "bi-shield-check") me-1"></i>
                @(ra.IsApproved ? "Revoke Approval" : "Approve Assessment")
            </button>
            <button class="btn btn-primary fw-bold px-4" @onclick="SaveRA">Save Assessment</button>
        </div>
    </div>

    <div class="row g-4">
        @* --- TOP HEADER INFO --- *@
        <div class="col-12">
            <div class="card border-0 shadow-sm p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="small fw-bold">Assessment Title</label>
                        <input type="text" class="form-control form-control-lg" @bind="ra.Title" placeholder="e.g. Workshop Tool Usage" />
                    </div>
                    <div class="col-md-3">
                        <label class="small fw-bold">Type</label>
                        <select class="form-select form-select-lg" @bind="ra.Type">
                            @foreach (var type in Enum.GetValues<RiskAssessmentType>())
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="small fw-bold">Review Due Date</label>
                        <input type="date" class="form-control form-control-lg" @bind="ra.ReviewDueDate" />
                    </div>
                </div>
            </div>
        </div>

        @* --- HAZARD GRID --- *@
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center p-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-exclamation-octagon me-2"></i>Hazards & Control Measures</h6>
                    <button class="btn btn-sm btn-outline-light" @onclick="AddHazard">+ Add Hazard Row</button>
                </div>
                <div class="card-body p-0">
                    <table class="table table-bordered align-middle mb-0 text-center">
                        <thead class="bg-light small fw-bold">
                            <tr>
                                <th rowspan="2" style="width: 20%;" class="text-start ps-3">Hazard Description</th>
                                <th rowspan="2" style="width: 15%;">Who is at Risk?</th>
                                <th colspan="3" class="bg-danger-subtle">Initial Risk</th>
                                <th rowspan="2" style="width: 25%;">Control Measures (Mitigation)</th>
                                <th colspan="3" class="bg-success-subtle">Residual Risk</th>
                                <th rowspan="2" style="width: 40px;"></th>
                            </tr>
                            <tr class="small">
                                <th style="width: 50px;" class="bg-danger-subtle">L</th>
                                <th style="width: 50px;" class="bg-danger-subtle">S</th>
                                <th style="width: 50px;" class="bg-danger-subtle">Score</th>
                                <th style="width: 50px;" class="bg-success-subtle">L</th>
                                <th style="width: 50px;" class="bg-success-subtle">S</th>
                                <th style="width: 50px;" class="bg-success-subtle">Score</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in hazards)
                            {
                                <tr>
                                    <td class="p-2"><textarea class="form-control form-control-sm border-0" rows="2" @bind="h.HazardName"></textarea></td>
                                    <td class="p-2"><input type="text" class="form-control form-control-sm border-0" @bind="h.WhoIsAtRisk" /></td>
                                    
                                    @* INITIAL RISK *@
                                    <td class="p-1"><input type="number" min="1" max="5" class="form-control form-control-sm text-center border-0" @bind="h.InitialLikelihood" /></td>
                                    <td class="p-1"><input type="number" min="1" max="5" class="form-control form-control-sm text-center border-0" @bind="h.InitialSeverity" /></td>
                                    <td class="fw-bold" style="background-color: @GetMatrixColor(h.InitialLikelihood * h.InitialSeverity)">
                                        @(h.InitialLikelihood* h.InitialSeverity)
                                    </td>

                                    <td class="p-2"><textarea class="form-control form-control-sm border-0" rows="2" @bind="h.MitigationMeasures"></textarea></td>

                                    @* RESIDUAL RISK *@
                                    <td class="p-1"><input type="number" min="1" max="5" class="form-control form-control-sm text-center border-0" @bind="h.ResidualLikelihood" /></td>
                                    <td class="p-1"><input type="number" min="1" max="5" class="form-control form-control-sm text-center border-0" @bind="h.ResidualSeverity" /></td>
                                    <td class="fw-bold" style="background-color: @GetMatrixColor(h.ResidualLikelihood * h.ResidualSeverity)">
                                        @(h.ResidualLikelihood* h.ResidualSeverity)
                                    </td>

                                    <td><button class="btn btn-sm text-danger" @onclick="() => hazards.Remove(h)"><i class="bi bi-trash"></i></button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int raId { get; set; }
    [SupplyParameterFromQuery] public int? prodId { get; set; }

    private RiskAssessment ra = new();
    private List<RAHazard> hazards = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        if (raId != 0)
        {
            ra = await context.RiskAssessments.Include(r => r.Hazards).FirstAsync(r => r.Id == raId);
            hazards = ra.Hazards.ToList();
        }
        else if (prodId.HasValue)
        {
            // Initializing a new Production RA
            var prod = await context.Productions.FindAsync(prodId);
            ra = new RiskAssessment
            {
                Title = $"Production RA: {prod?.Title}",
                Type = RiskAssessmentType.Production,
                ProductionId = prodId,
                AssessedBy = "System"
            };
            // Logic to pull template hazards could go here
        }
    }

    private void AddHazard() => hazards.Add(new RAHazard { InitialLikelihood = 1, InitialSeverity = 1, ResidualLikelihood = 1, ResidualSeverity = 1 });

    private async Task SaveRA()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        if (ra.Id != 0)
        {
            // 1. If editing, remove the old hazards from the database first
            var existingHazards = await context.RAHazards
                .Where(h => h.RiskAssessmentId == ra.Id)
                .ToListAsync();
            context.RAHazards.RemoveRange(existingHazards);
        
            // Save the deletions first to prevent primary key conflicts
            await context.SaveChangesAsync();
        
            context.RiskAssessments.Update(ra);
        }
        else
        {
            // 2. If new, just add the parent to the context
            context.RiskAssessments.Add(ra);
        }

        // 3. Clear the navigation collection and rebuild it from the UI list
        // This ensures EF handles the Foreign Key relationship automatically
        ra.Hazards = new List<RAHazard>();

        foreach (var h in hazards)
        {
            ra.Hazards.Add(new RAHazard
            {
                HazardName = h.HazardName,
                WhoIsAtRisk = h.WhoIsAtRisk,
                InitialLikelihood = h.InitialLikelihood,
                InitialSeverity = h.InitialSeverity,
                MitigationMeasures = h.MitigationMeasures,
                ResidualLikelihood = h.ResidualLikelihood,
                ResidualSeverity = h.ResidualSeverity
                // IMPORTANT: We do NOT set RiskAssessmentId here.
                // EF handles it because it's inside the ra.Hazards list.
            });
        }

        // 4. Final Save - SQL will now insert in the correct order
        await context.SaveChangesAsync();

        Nav.NavigateTo("/admin/hs/risk-assessments");
    }

    private string GetMatrixColor(int score) => score switch
    {
        <= 4 => "#d1e7dd", // Green (Low)
        <= 9 => "#fff3cd", // Yellow (Medium)
        <= 15 => "#f8d7da", // Amber (High)
        _ => "#dc3545"      // Red (Very High)
    };

    private void ToggleApproval() { ra.IsApproved = !ra.IsApproved; ra.ApprovedBy = ra.IsApproved ? "Technical Manager" : null; }
}