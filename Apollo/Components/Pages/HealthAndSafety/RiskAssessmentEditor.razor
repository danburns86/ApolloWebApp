@page "/admin/hs/risk-assessments/edit/{raId:int}"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<div class="container py-4 max-w-7xl">
    @if (ra == null)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <a href="/admin/hs/risk-assessments" class="text-decoration-none small text-muted"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
                <h2 class="fw-bold mt-1">@(ra.Id == 0 ? "New Risk Assessment" : "Edit Assessment")</h2>
                @if (ra.Production != null)
                {
                    <span class="badge bg-info">Production: @ra.Production.Title</span>
                }
            </div>
            <div class="d-flex gap-2">
                @if (ra.Id != 0)
                {
                    <button class="btn @(ra.IsApproved ? "btn-warning" : "btn-success")" @onclick="ToggleApproval">
                        <i class="bi @(ra.IsApproved ? "bi-unlock" : "bi-shield-check") me-1"></i>
                        @(ra.IsApproved ? "Revoke Approval" : "Approve Assessment")
                    </button>
                }
                <button class="btn btn-primary fw-bold px-4 shadow-sm" @onclick="SaveRA">
                    <i class="bi bi-save me-2"></i>Save Assessment
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger shadow-sm mb-4">@errorMessage</div>
        }

        <div class="card border-0 shadow-sm p-4 mb-4">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="small fw-bold">Assessment Title</label>
                    <input type="text" class="form-control" @bind="ra.Title" />
                </div>
                <div class="col-md-3">
                    <label class="small fw-bold">Type</label>
                    <select class="form-select" @bind="ra.Type">
                        @foreach (var type in Enum.GetValues<RiskAssessmentType>())
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="small fw-bold">Review Due Date</label>
                    <input type="date" class="form-control" @bind="ra.ReviewDueDate" />
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center p-3">
                <h6 class="mb-0 fw-bold">Hazards & Control Measures</h6>
                <button class="btn btn-sm btn-outline-light" @onclick="AddHazard">+ Add Hazard Row</button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle mb-0 text-center">
                        <thead class="bg-light small fw-bold">
                            <tr>
                                <th style="width: 25%;" class="text-start ps-3">Hazard Description</th>
                                <th style="width: 15%;">Who is at risk?</th>
                                <th style="width: 60px;">Init L</th>
                                <th style="width: 60px;">Init S</th>
                                <th style="width: 60px;">Score</th>
                                <th>Control Measures</th>
                                <th style="width: 60px;">Res L</th>
                                <th style="width: 60px;">Res S</th>
                                <th style="width: 60px;">Score</th>
                                <th style="width: 45px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in hazards)
                            {
                                <tr>
                                    <td class="p-1"><textarea class="form-control form-control-sm border-0" rows="2" @bind="h.HazardName"></textarea></td>
                                    <td class="p-1"><input type="text" class="form-control form-control-sm border-0" @bind="h.WhoIsAtRisk" /></td>
                                    <td><input type="number" min="1" max="5" class="form-control form-control-sm border-0 text-center" @bind="h.InitialLikelihood" /></td>
                                    <td><input type="number" min="1" max="5" class="form-control form-control-sm border-0 text-center" @bind="h.InitialSeverity" /></td>
                                    <td class="fw-bold" style="background-color: @GetMatrixColor(h.InitialLikelihood * h.InitialSeverity)">@(h.InitialLikelihood* h.InitialSeverity)</td>
                                    <td class="p-1"><textarea class="form-control form-control-sm border-0" rows="2" @bind="h.MitigationMeasures"></textarea></td>
                                    <td><input type="number" min="1" max="5" class="form-control form-control-sm border-0 text-center" @bind="h.ResidualLikelihood" /></td>
                                    <td><input type="number" min="1" max="5" class="form-control form-control-sm border-0 text-center" @bind="h.ResidualSeverity" /></td>
                                    <td class="fw-bold" style="background-color: @GetMatrixColor(h.ResidualLikelihood * h.ResidualSeverity)">@(h.ResidualLikelihood* h.ResidualSeverity)</td>
                                    <td><button class="btn btn-sm text-danger" @onclick="() => hazards.Remove(h)"><i class="bi bi-trash"></i></button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int raId { get; set; }
    [SupplyParameterFromQuery] public int? prodId { get; set; }

    private RiskAssessment ra = new();
    private List<RAHazard> hazards = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            if (raId != 0)
            {
                // We load Production only for the title to avoid deep circular references
                ra = await context.RiskAssessments
                    .Include(r => r.Hazards)
                    .Include(r => r.Production)
                    .FirstOrDefaultAsync(r => r.Id == raId) ?? new();
                hazards = ra.Hazards.ToList();
            }
            else if (prodId.HasValue)
            {
                var prod = await context.Productions.FindAsync(prodId);
                ra = new RiskAssessment
                {
                    Title = $"Show RA: {prod?.Title}",
                    Type = RiskAssessmentType.Production,
                    ProductionId = prodId,
                    AssessmentDate = DateTime.Today,
                    ReviewDueDate = DateTime.Today.AddMonths(6)
                };
            }
        }
        catch (Exception ex) { errorMessage = $"Error loading data: {ex.Message}"; }
    }

    private void AddHazard() => hazards.Add(new RAHazard { InitialLikelihood = 1, InitialSeverity = 1, ResidualLikelihood = 1, ResidualSeverity = 1 });

    private async Task ToggleApproval()
    {
        ra.IsApproved = !ra.IsApproved;
        ra.ApprovedBy = ra.IsApproved ? "Technical Manager" : null;
        // We trigger an auto-save here to ensure the circuit state is preserved
        await SaveRA();
    }

    private async Task SaveRA()
    {
        errorMessage = null;
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            if (ra.Id != 0)
            {
                // Remove old hazards to ensure a clean sync
                var old = await context.RAHazards.Where(h => h.RiskAssessmentId == ra.Id).ToListAsync();
                context.RAHazards.RemoveRange(old);
                await context.SaveChangesAsync();

                context.RiskAssessments.Update(ra);
            }
            else
            {
                context.RiskAssessments.Add(ra);
            }

            // Map the UI list to the DB entity
            ra.Hazards = hazards.Select(h => new RAHazard
            {
                HazardName = h.HazardName,
                WhoIsAtRisk = h.WhoIsAtRisk,
                InitialLikelihood = h.InitialLikelihood,
                InitialSeverity = h.InitialSeverity,
                MitigationMeasures = h.MitigationMeasures,
                ResidualLikelihood = h.ResidualLikelihood,
                ResidualSeverity = h.ResidualSeverity
            }).ToList();

            await context.SaveChangesAsync();
            Nav.NavigateTo("/admin/hs/risk-assessments");
        }
        catch (Exception ex) { errorMessage = $"Database Error: {ex.Message}"; StateHasChanged(); }
    }

    private string GetMatrixColor(int score) => score switch
    {
        <= 4 => "#d1e7dd",
        <= 9 => "#fff3cd",
        <= 15 => "#f8d7da",
        _ => "#dc3545"
    };

    private async Task LogFormalReview()
    {
        using var context = await DbFactory.CreateDbContextAsync();
    
        var reviewRecord = new RiskAssessmentReview
        {
            RiskAssessmentId = ra.Id,
            ReviewDate = DateTime.Now,
            ReviewedBy = "Technical Manager", // Replace with logged-in user later
            ReviewOutcome = "Periodic Review - Content remains accurate",
            NextReviewDueDate = DateTime.Today.AddYears(1)
        };
    
        ra.ReviewDueDate = reviewRecord.NextReviewDueDate;
        context.RiskAssessmentReviews.Add(reviewRecord);
        context.RiskAssessments.Update(ra);
    
        await context.SaveChangesAsync();
        Nav.NavigateTo("/admin/hs/risk-assessments");
    }
}