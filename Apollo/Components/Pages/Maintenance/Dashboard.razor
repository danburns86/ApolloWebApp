@page "/admin/maintenance"
@using Apollo.Models
@using Apollo.Data
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = SystemPermissions.ManageMaintenance)]
@inject IMaintenanceService MaintenanceService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Maintenance Hub</PageTitle>

<div class="container-fluid px-4 py-4 max-w-7xl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Maintenance Hub</h2>
            <p class="text-muted">Master control for theatre facilities and asset repairs.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary shadow-sm" @onclick="LoadSnags">
                <i class="bi bi-arrow-clockwise me-1"></i>Refresh
            </button>
            <a href="/admin/maintenance/new" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Log New Snag
            </a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-danger"></div></div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-4 border-danger h-100">
                    <div class="card-body py-3">
                        <div class="text-uppercase small fw-bold text-muted mb-1">New / Triage</div>
                        @* Pending is the starting status in your service *@
                        <div class="h2 fw-bold mb-0">@issues.Count(i => i.Status == SnagStatus.Pending)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-4 border-primary h-100">
                    <div class="card-body py-3">
                        <div class="text-uppercase small fw-bold text-muted mb-1">In Progress</div>
                        <div class="h2 fw-bold mb-0">@issues.Count(i => i.Status == SnagStatus.InProgress)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-4 border-warning h-100">
                    <div class="card-body py-3">
                        <div class="text-uppercase small fw-bold text-muted mb-1">Waiting on Parts</div>
                        <div class="h2 fw-bold mb-0">@issues.Count(i => i.Status == SnagStatus.PartsRequired)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-4 border-info h-100">
                    <div class="card-body py-3">
                        <div class="text-uppercase small fw-bold text-muted mb-1">External Contractor</div>
                        <div class="h2 fw-bold mb-0">@issues.Count(i => i.Status == SnagStatus.ContractorRequired)</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="accordion shadow-sm mb-4" id="maintAccordion">
            
            <div class="accordion-item border-0 mb-2 rounded shadow-sm overflow-hidden">
                <h2 class="accordion-header">
                    <button class="accordion-button fw-bold @(IsExpanded("triage") ? "" : "collapsed")" type="button" @onclick='() => ToggleAccordion("triage")'>
                        <i class="bi bi-clipboard-pulse me-2 text-danger"></i> Triage Queue
                        <span class="badge bg-danger ms-2">@issues.Count(i => i.Status == SnagStatus.Pending)</span>
                    </button>
                </h2>
                <div class="accordion-collapse collapse @(IsExpanded("triage") ? "show" : "")">
                    <div class="accordion-body bg-light">
                        <div class="row g-3">
                            @foreach (var issue in issues.Where(i => i.Status == SnagStatus.Pending))
                            {
                                <div class="col-md-6 col-lg-4">@RenderSnagCard(issue)</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="accordion-item border-0 mb-2 rounded shadow-sm overflow-hidden">
                <h2 class="accordion-header">
                    <button class="accordion-button fw-bold @(IsExpanded("active") ? "" : "collapsed")" type="button" @onclick='() => ToggleAccordion("active")'>
                        <i class="bi bi-tools me-2 text-primary"></i> Active Repairs
                        <span class="badge bg-primary ms-2">@issues.Count(i => i.Status == SnagStatus.InProgress)</span>
                    </button>
                </h2>
                <div class="accordion-collapse collapse @(IsExpanded("active") ? "show" : "")">
                    <div class="accordion-body bg-light">
                        <div class="row g-3">
                            @foreach (var issue in issues.Where(i => i.Status == SnagStatus.InProgress))
                            {
                                <div class="col-md-6 col-lg-4">@RenderSnagCard(issue)</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="accordion-item border-0 mb-5 rounded shadow-sm overflow-hidden">
                <h2 class="accordion-header">
                    <button class="accordion-button fw-bold @(IsExpanded("reports") ? "" : "collapsed") bg-dark text-white" type="button" @onclick='() => ToggleAccordion("reports")'>
                        <i class="bi bi-file-earmark-bar-graph me-2"></i> Maintenance Reports
                    </button>
                </h2>
                <div class="accordion-collapse collapse @(IsExpanded("reports") ? "show" : "")">
                    <div class="accordion-body bg-white border">
                        <div class="row g-4 text-center">
                            <div class="col-md-4">
                                <a href="/admin/maintenance/reports/triage" class="text-decoration-none">
                                    <div class="p-3 border rounded hover-bg-light">
                                        <i class="bi bi-clipboard-pulse text-danger fs-3 d-block mb-2"></i>
                                        <h6 class="fw-bold text-dark mb-0">Needs Triage</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="/admin/maintenance/reports/outstanding" class="text-decoration-none">
                                    <div class="p-3 border rounded hover-bg-light">
                                        <i class="bi bi-tools text-primary fs-3 d-block mb-2"></i>
                                        <h6 class="fw-bold text-dark mb-0">Outstanding Jobs</h6>
                                    </div>
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="/admin/maintenance/reports/parts" class="text-decoration-none">
                                    <div class="p-3 border rounded hover-bg-light">
                                        <i class="bi bi-cart text-info fs-3 d-block mb-2"></i>
                                        <h6 class="fw-bold text-dark mb-0">Parts Order List</h6>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-center gap-3 mb-5 py-3 border-top">
            <button class="btn btn-sm btn-secondary opacity-75 fw-bold" @onclick="() => SetAllAccordions(true)">
                <i class="bi bi-arrows-expand me-2"></i>Expand All
            </button>
            <button class="btn btn-sm btn-secondary opacity-75 fw-bold" @onclick="() => SetAllAccordions(false)">
                <i class="bi bi-arrows-collapse me-2"></i>Collapse All
            </button>
        </div>
    }
</div>

@if (selectedIssue != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.6); z-index: 1060;" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header @GetSeverityBgClass(selectedIssue.Severity) text-white border-0">
                    <h5 class="modal-title fw-bold">Issue Triage #@selectedIssue.Id</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-4 mb-4">
                        <div class="col-md-7">
                            <h6 class="fw-bold text-muted text-uppercase small mb-1">Location</h6>
                            <p class="fs-5 fw-bold mb-3">@selectedIssue.Room?.Area?.Name &gt; @selectedIssue.Room?.Name</p>
                            <h6 class="fw-bold text-muted text-uppercase small mb-1">Problem Description</h6>
                            <div class="p-3 bg-light rounded border mb-3">@selectedIssue.Description</div>
                        </div>
                        <div class="col-md-5">
                            @if (!string.IsNullOrEmpty(selectedIssue.ImagePath))
                            {
                                <a href="@selectedIssue.ImagePath" target="_blank">
                                    <img src="@selectedIssue.ImagePath" class="img-fluid rounded shadow-sm border w-100" style="max-height: 220px; object-fit: cover;" />
                                </a>
                            }
                        </div>
                    </div>

                    <div class="bg-light p-4 rounded border">
                        <h6 class="fw-bold mb-3">Resolution & Assignment</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="small fw-bold">Update Status</label>
                                <select class="form-select" @bind="newStatus">
                                    @foreach (var status in Enum.GetValues<SnagStatus>())
                                    {
                                        <option value="@status">@status.ToString().Replace("ContractorRequired", "Contractor Required")</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold">Assign Technician</label>
                                <input type="text" class="form-control" @bind="assignedTo" placeholder="Name..." />
                            </div>
                            <div class="col-12">
                                <label class="small fw-bold">Action Taken / Admin Notes</label>
                                <textarea class="form-control" @bind="adminNotes" rows="3" placeholder="Notes for the timeline..."></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" @onclick="SaveTriage">Commit Updates</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MaintenanceIssue> issues = new();
    private bool isLoading = true;
    private HashSet<string> expandedGroups = new() { "triage" };

    private void ToggleAccordion(string id)
    {
        if (expandedGroups.Contains(id)) expandedGroups.Remove(id);
        else expandedGroups.Add(id);
    }
    private bool IsExpanded(string id) => expandedGroups.Contains(id);
    private void SetAllAccordions(bool expand)
    {
        if (expand) expandedGroups = new HashSet<string> { "triage", "active", "parts", "external", "reports" };
        else expandedGroups.Clear();
    }

    private MaintenanceIssue? selectedIssue;
    private SnagStatus newStatus;
    // Initialized to string.Empty to prevent Null Reference warnings
    private string adminNotes = string.Empty;
    private string assignedTo = string.Empty;
    private string contractorName = string.Empty;
    private string quoteRef = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadSnags();

    private async Task LoadSnags()
    {
        isLoading = true;
        // MaintenanceService.GetPendingSnags() filters for Pending, PartsRequired, InProgress [cite: 13]
        issues = await MaintenanceService.GetPendingSnags();
        isLoading = false;
    }

    private void OpenTriageModal(MaintenanceIssue issue)
    {
        selectedIssue = issue;
        newStatus = issue.Status;
        adminNotes = issue.AdminNotes ?? string.Empty;
        assignedTo = issue.AssignedTo ?? string.Empty;
        contractorName = issue.ContractorCompany ?? string.Empty;
        quoteRef = issue.QuoteReference ?? string.Empty;
    }

    private void CloseModal() => selectedIssue = null;

    private async Task SaveTriage()
    {
        if (selectedIssue != null)
        {
            // Passes exact variables required by your IMaintenanceService
            await MaintenanceService.UpdateSnagStatus(selectedIssue.Id, newStatus, adminNotes, assignedTo, contractorName, quoteRef);
            await LoadSnags();
            CloseModal();
        }
    }

    private RenderFragment RenderSnagCard(MaintenanceIssue snag) => __builder =>
    {
        <div class="card h-100 shadow-sm border-0 border-start border-4 @GetSeverityBorderClass(snag.Severity)">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="badge @GetSeverityBadgeClass(snag.Severity)">@snag.Severity</span>
                    <small class="text-muted fw-bold">@snag.ReportedAt.ToString("MMM dd")</small>
                </div>
                <h6 class="fw-bold mb-1">@snag.Room?.Name</h6>
                <p class="small text-muted mb-2"><i class="bi bi-geo-alt me-1"></i>@(snag.Room?.Area?.Name ?? "Theatre")</p>
                <p class="card-text small text-dark mb-3">
                    @(snag.Description.Length > 85 ? snag.Description.Substring(0, 85) + "..." : snag.Description)
                </p>
            </div>
            <div class="card-footer bg-white border-0 pt-0 pb-3">
                <button class="btn btn-sm btn-dark w-100 fw-bold" @onclick="() => OpenTriageModal(snag)">Triage Issue</button>
            </div>
        </div>
    };

    private string GetSeverityBorderClass(SnagSeverity severity) => severity switch
    {
        SnagSeverity.Emergency => "border-danger",
        SnagSeverity.High => "border-warning",
        SnagSeverity.Medium => "border-primary",
        _ => "border-secondary"
    };

    private string GetSeverityBadgeClass(SnagSeverity severity) => severity switch
    {
        SnagSeverity.Emergency => "bg-danger",
        SnagSeverity.High => "bg-warning text-dark",
        SnagSeverity.Medium => "bg-primary",
        _ => "bg-secondary"
    };

    private string GetSeverityBgClass(SnagSeverity severity) => severity switch
    {
        SnagSeverity.Emergency => "bg-danger",
        SnagSeverity.High => "bg-warning text-dark",
        _ => "bg-dark"
    };
}