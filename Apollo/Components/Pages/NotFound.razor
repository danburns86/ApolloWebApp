@page "/not-found"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<PageTitle>Page Not Found</PageTitle>

<div class="container text-center py-5 mt-5">
    <h1 class="display-1 fw-bold text-secondary mb-0">404</h1>
    <h2 class="fw-bold mb-4">Dead End</h2>
    <p class="text-muted mb-4">The page you are looking for doesn't exist, has been moved, or you don't have access to it.</p>
    <a href="/" class="btn btn-primary px-4 fw-bold shadow-sm">
        <i class="bi bi-house me-2"></i> Return to Dashboard
    </a>
</div>