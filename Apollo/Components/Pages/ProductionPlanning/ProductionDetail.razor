@page "/admin/production/hub/{id:int}"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<div class="container-fluid py-4 max-w-7xl">
    @* --- HEADER --- *@
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <a href="/admin/production" class="text-decoration-none small text-muted"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
            <h2 class="fw-bold mt-1">@prod?.Title <span class="badge bg-primary ms-2 fs-6">@prod?.Category?.Name</span></h2>
        </div>
        <div class="d-flex gap-2">
            @if (showSavedAlert)
            {
                <span class="text-success mt-2">Saved!</span>
            }
            <button class="btn btn-primary fw-bold px-4" @onclick="SaveHub"><i class="bi bi-save me-2"></i>Save Hub Changes</button>
        </div>
    </div>

    @if (prod == null)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="row g-4">
            @* --- LEFT: CREW & PERFORMANCES --- *@
            <div class="col-lg-7">
                
                @* MASTER ROTA *@
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom p-3 d-flex justify-content-between align-items-center">
                        <h6 class="fw-bold mb-0 text-warning">Master Rota (Run Defaults)</h6>
                        <button class="btn btn-sm btn-outline-dark" @onclick="AddNewCrewRow">+ Add Role</button>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light small">
                                <tr><th style="width:40px;" class="ps-3">Req?</th><th>Role</th><th>Assignee</th><th style="width:40px;"></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var crew in crewList)
                                {
                                    <tr>
                                        <td class="ps-3"><input type="checkbox" @bind="crew.IsRequired" /></td>
                                        <td class="position-relative">
                                            <input type="text" class="form-control form-control-sm" value="@(crew.Role?.Name ?? crew.CustomRoleName)" @oninput="(e) => SearchRoles(crew, e)" />
                                            @if (activeRoleSearch == crew && filteredRoles.Any())
                                            {
                                                <div class="list-group position-absolute z-3 shadow-lg w-100">
                                                    @foreach (var r in filteredRoles)
                                                    {
                                                        <button class="list-group-item list-group-item-action small py-1" @onclick="() => SelectRole(crew, r)">@r.Name</button>
                                                    }
                                                </div>
                                            }
                                        </td>
                                        <td class="position-relative">
                                            <div class="input-group input-group-sm">
                                                @if (crew.MemberId != null)
                                                {
                                                    <span class="input-group-text bg-success-subtle text-success border-success w-100 justify-content-between">
                                                        <span>@crew.Member?.FullName</span>
                                                        <i class="bi bi-x-lg cursor-pointer" @onclick="() => ClearAssignee(crew)"></i>
                                                    </span>
                                                }
                                                else
                                                {
                                                    <input type="text" class="form-control" placeholder="Search members..." value="@crew.ExternalName" @oninput="(e) => SearchMembers(crew, e)" />
                                                }
                                            </div>
                                            @if (activeMemberSearch == crew && filteredMembers.Any())
                                            {
                                                <div class="list-group position-absolute z-3 shadow-lg w-100">
                                                    @foreach (var m in filteredMembers)
                                                    {
                                                        <button class="list-group-item list-group-item-action small py-1" @onclick="() => SelectMember(crew, m)">@m.FullName</button>
                                                    }
                                                </div>
                                            }
                                        </td>
                                        <td class="pe-3"><button class="btn btn-sm text-danger" @onclick="() => crewList.Remove(crew)"><i class="bi bi-trash"></i></button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @* PERFORMANCES *@
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom p-3 d-flex justify-content-between align-items-center">
                        <h6 class="fw-bold mb-0 text-primary">Performances</h6>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => showGenerator = !showGenerator">Run Generator</button>
                    </div>
                    @if (showGenerator)
                    {
                        <div class="card-body bg-light border-bottom p-3">
                            <div class="row g-3 align-items-end">
                                <div class="col-md-3">
                                    <label class="small fw-bold">Default Time</label>
                                    <input type="time" class="form-control form-control-sm" @bind="genTime" />
                                </div>
                                <div class="col-md-6">
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)))
                                        {
                                            <div class="form-check"><input type="checkbox" @onchange="(e) => ToggleGenDay(day, e)" checked="@genDays.Contains(day)" /> <label class="small">@day.ToString().Substring(0, 3)</label></div>
                                        }
                                    </div>
                                </div>
                                <div class="col-md-3"><button class="btn btn-sm btn-primary w-100" @onclick="GeneratePerformances">Generate</button></div>
                            </div>
                        </div>
                    }
                    <div class="card-body p-0">
                        <table class="table table-sm align-middle mb-0">
                            <tbody>
                                @foreach (var perf in performances.OrderBy(p => p.CurtainUp))
                                {
                                    <tr>
                                        <td class="ps-3 small">@perf.CurtainUp.ToString("ddd dd MMM HH:mm")</td>
                                        <td><input type="text" class="form-control form-control-sm border-0" @bind="perf.PerformanceTitle" placeholder="Note (Gala, etc)" /></td>
                                        <td class="text-end pe-3">
                                            <button class="btn btn-sm btn-outline-warning" @onclick="() => OpenSwapModal(perf)"><i class="bi bi-person-exclamation"></i></button>
                                            <button class="btn btn-sm text-danger" @onclick="() => performances.Remove(perf)"><i class="bi bi-x"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <button class="btn btn-sm btn-link m-2 text-decoration-none" @onclick="AddSinglePerformance">+ Extra Show</button>
                    </div>
                </div>
            </div>

            @* --- RIGHT: TECH & EXTERNAL --- *@
            <div class="col-lg-5">
                @if (prod.Category?.IsExternal == true)
                {
                    <div class="card border-0 shadow-sm p-3 mb-4 border-start border-4 border-success">
                        <h6 class="fw-bold text-success small text-uppercase">Hire Details</h6>
                        <input type="text" class="form-control mt-2" @bind="prod.HirerName" placeholder="Hirer Name" />
                        <input type="time" class="form-control mt-2" @bind="prod.AccessTime" />
                    </div>
                }
                <div class="card border-0 shadow-sm p-4 bg-dark text-white mb-4">
                    <h6 class="fw-bold border-bottom border-secondary pb-2">Technical Summary</h6>
                    <textarea class="form-control bg-dark text-white border-secondary mt-3" rows="10" @bind="prod.TechRequirements"></textarea>
                </div>

                @* --- LOGISTICS & FOH SECTION --- *@
                <div class="card border-0 shadow-sm p-3 mb-4 border-start border-4 border-info">
                    <h6 class="fw-bold text-info small text-uppercase mb-3">Logistics & FOH</h6>
    
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="small fw-bold">Running Time (Mins)</label>
                            <input type="number" class="form-control form-control-sm" @bind="prod.RunningTimeMinutes" />
                        </div>
                        <div class="col-6">
                            <label class="small fw-bold">Interval (Mins)</label>
                            <input type="number" class="form-control form-control-sm" @bind="prod.IntervalMinutes" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="small fw-bold text-danger">Content Warnings</label>
                        <input type="text" class="form-control form-control-sm" @bind="prod.ContentWarnings" placeholder="e.g. Strobes, Haze, Pyrotechnics" />
                    </div>

                    <div class="mb-3">
                        <label class="small fw-bold">Security / Unlocker</label>
                        <select class="form-select form-select-sm" @bind="prod.UnlockingMemberId">
                            <option value="">-- Select Member --</option>
                            @foreach (var m in allMembers)
                            {
                                <option value="@m.Id">@m.FullName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-0">
                        <label class="small fw-bold">FOH Instructions</label>
                        <textarea class="form-control form-control-sm" rows="3" @bind="prod.FOHNotes" placeholder="Notes for Ushers/Bar staff..."></textarea>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* CREW SWAP MODAL *@
@if (showSwapModal && activePerf != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-warning border-0">
                    <h6 class="fw-bold mb-0">Swaps for @activePerf.CurtainUp.ToString("ddd dd MMM")</h6>
                    <button class="btn-close" @onclick="() => showSwapModal = false"></button>
                </div>
                <div class="modal-body">
                    @foreach (var master in crewList)
                    {
                        var roleName = master.Role?.Name ?? master.CustomRoleName;
                        var masterName = master.Member?.FullName ?? master.ExternalName ?? "Nobody";
                        var currentOverride = activePerf.Overrides.FirstOrDefault(o => o.RoleId == master.RoleId && o.CustomRoleName == master.CustomRoleName);

                        <div class="mb-3 p-2 border rounded">
                            <label class="small fw-bold">@roleName <span class="fw-normal text-muted">(Master: @masterName)</span></label>
                            <input type="text" class="form-control form-control-sm" placeholder="Type Stand-in Name..."
                                   value="@currentOverride?.ExternalName" @oninput="(e) => UpdateOverride(master, e.Value?.ToString())" />
                        </div>
                    }
                </div>
                <div class="modal-footer"><button class="btn btn-warning w-100 fw-bold" @onclick="() => showSwapModal = false">Done</button></div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int id { get; set; }
    private Production? prod;
    private List<ProductionCrew> crewList = new();
    private List<Performance> performances = new();
    private List<ProductionCredit> credits = new();
    private bool showSavedAlert = false;

    // Search/UI States (The ones that were missing!)
    private bool showGenerator = false;
    private DateTime genTime = DateTime.Today.AddHours(19).AddMinutes(30);
    private List<DayOfWeek> genDays = new() { DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday };
    
    private List<ProductionRole> allTemplateRoles = new();
    private List<ProductionRole> filteredRoles = new();
    private ProductionCrew? activeRoleSearch;

    private List<Member> allMembers = new();
    private List<Member> filteredMembers = new();
    private ProductionCrew? activeMemberSearch;

    private bool showSwapModal = false;
    private Performance? activePerf;
    private List<ProductionEventType> eventTypes = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        prod = await context.Productions.Include(p => p.Category).FirstOrDefaultAsync(p => p.Id == id);
        if (prod != null)
        {
            crewList = await context.ProductionCrews.Include(c => c.Role).Include(c => c.Member).Where(c => c.ProductionId == id).ToListAsync();
            performances = await context.Performances.Include(p => p.Overrides).Where(p => p.ProductionId == id).ToListAsync();
            credits = await context.ProductionCredits.Where(c => c.ProductionId == id).ToListAsync();
            allMembers = await context.Members.OrderByDescending(m => m.IsTechTeam).ToListAsync();
            allTemplateRoles = await context.ProductionRoles.Where(r => r.CategoryId == prod.CategoryId).ToListAsync();
            
            if (!crewList.Any())
            {
                foreach (var r in allTemplateRoles) crewList.Add(new ProductionCrew { ProductionId = id, RoleId = r.Id, Role = r, IsRequired = r.IsMandatory });
            }
        }
    }

    // --- SEARCH LOGIC ---
    private void SearchRoles(ProductionCrew crew, ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        activeRoleSearch = crew; crew.RoleId = null; crew.Role = null; crew.CustomRoleName = val;
        filteredRoles = allTemplateRoles.Where(r => r.Name.Contains(val, StringComparison.OrdinalIgnoreCase)).ToList();
    }
    private void SelectRole(ProductionCrew crew, ProductionRole r)
    {
        crew.RoleId = r.Id; crew.Role = r; crew.CustomRoleName = null; activeRoleSearch = null;
    }
    private void SearchMembers(ProductionCrew crew, ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        activeMemberSearch = crew; crew.ExternalName = val;
        filteredMembers = allMembers.Where(m => m.FullName.Contains(val, StringComparison.OrdinalIgnoreCase)).Take(10).ToList();
    }
    private void SelectMember(ProductionCrew crew, Member m)
    {
        crew.MemberId = m.Id; crew.Member = m; crew.ExternalName = null; activeMemberSearch = null;
    }
    private void ClearAssignee(ProductionCrew crew) { crew.MemberId = null; crew.Member = null; crew.ExternalName = null; }

    // --- GENERATOR LOGIC ---
    private void ToggleGenDay(DayOfWeek d, ChangeEventArgs e) { if ((bool)e.Value!) genDays.Add(d); else genDays.Remove(d); }
    private void GeneratePerformances()
    {
        for (var date = prod!.StartDate; date <= prod.EndDate; date = date.AddDays(1))
        {
            if (genDays.Contains(date.DayOfWeek)) performances.Add(new Performance { ProductionId = id, CurtainUp = date.Date.Add(genTime.TimeOfDay), PerformanceTitle = "Standard Show" });
        }
        showGenerator = false;
    }

    private void AddNewCrewRow() => crewList.Add(new ProductionCrew { ProductionId = id, IsRequired = true });
    private void AddSinglePerformance() => performances.Add(new Performance { ProductionId = id, CurtainUp = prod!.StartDate.AddHours(19.5) });
    private void AddCreditRow() => credits.Add(new ProductionCredit { ProductionId = id });

    private void OpenSwapModal(Performance p) { activePerf = p; showSwapModal = true; }
    private void UpdateOverride(ProductionCrew role, string? name)
    {
        if (activePerf == null) return;
        var existing = activePerf.Overrides.FirstOrDefault(o => o.RoleId == role.RoleId && o.CustomRoleName == role.CustomRoleName);
        if (string.IsNullOrWhiteSpace(name)) { if (existing != null) activePerf.Overrides.Remove(existing); }
        else
        {
            if (existing == null) { existing = new PerformanceCrewOverride { PerformanceId = activePerf.Id, RoleId = role.RoleId, CustomRoleName = role.CustomRoleName }; activePerf.Overrides.Add(existing); }
            existing.ExternalName = name;
        }
    }

    private async Task SaveHub()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        context.Productions.Update(prod!);

        var oldCrew = await context.ProductionCrews.Where(c => c.ProductionId == id).ToListAsync();
        context.ProductionCrews.RemoveRange(oldCrew);
        context.ProductionCrews.AddRange(crewList.Select(c => new ProductionCrew { ProductionId = id, RoleId = c.RoleId, CustomRoleName = c.CustomRoleName, MemberId = c.MemberId, ExternalName = c.ExternalName, IsRequired = c.IsRequired }));

        var oldPerf = await context.Performances.Include(p => p.Overrides).Where(p => p.ProductionId == id).ToListAsync();
        context.Performances.RemoveRange(oldPerf);
        context.Performances.AddRange(performances);

        await context.SaveChangesAsync();
        showSavedAlert = true; StateHasChanged();
        await Task.Delay(2000); showSavedAlert = false; StateHasChanged();
    }
}