@page "/admin/production"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Production Hub</h2>
            <p class="text-muted">Theatre Operations & Scheduling</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/admin/production/settings" class="btn btn-outline-secondary"><i class="bi bi-gear me-1"></i>Settings</a>
            <button class="btn btn-primary shadow-sm" @onclick="OpenAddModal">
                <i class="bi bi-plus-lg me-1"></i>New Production
            </button>
        </div>
    </div>

    @* --- TOP TILES --- *@
    <div class="row g-3 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 bg-primary text-white">
                <div class="d-flex justify-content-between">
                    <div>
                        <h3 class="fw-bold mb-0">@productions.Count(p => p.StartDate >= DateTime.Today)</h3>
                        <span class="small text-white-50">Upcoming Shows</span>
                    </div>
                    <i class="bi bi-calendar-event fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 bg-danger text-white">
                <div class="d-flex justify-content-between">
                    <div>
                        <h3 class="fw-bold mb-0">@totalGaps</h3>
                        <span class="small text-white-50">Shows with Crew Gaps</span>
                    </div>
                    <i class="bi bi-exclamation-triangle fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 bg-success text-white">
                <div class="d-flex justify-content-between">
                    <div>
                        <h3 class="fw-bold mb-0">@(productions.Count(p => p.StartDate >= DateTime.Today) - totalGaps)</h3>
                        <span class="small text-white-50">Fully Crewed</span>
                    </div>
                    <i class="bi bi-people-fill fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 bg-dark text-white">
                <div class="d-flex justify-content-between">
                    <div>
                        <h3 class="fw-bold mb-0">@next30Days</h3>
                        <span class="small text-white-50">Shows (Next 30 Days)</span>
                    </div>
                    <i class="bi bi-clock-history fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var cat in categories)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="p-3 bg-light rounded-3 border mb-3 d-flex justify-content-between align-items-center">
                        <h6 class="fw-bold mb-0"><i class="bi @cat.IconClass me-2 text-primary"></i>@cat.Name</h6>
                        <span class="badge bg-dark rounded-pill">@productions.Count(p => p.CategoryId == cat.Id)</span>
                    </div>
                    
                    <div class="d-flex flex-column gap-3">
                        @foreach (var p in productions.Where(p => p.CategoryId == cat.Id).OrderBy(p => p.StartDate))
                        {
                            <div class="card border-0 shadow-sm border-start border-4 @(HasGaps(p) ? "border-danger" : "border-success")">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between">
                                        <h6 class="fw-bold mb-1">@p.Title</h6>
                                        @if (HasGaps(p))
                                        {
                                            <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                                        }
                                    </div>
                                    <div class="small text-muted mb-3">@p.StartDate.ToString("dd MMM") - @p.EndDate.ToString("dd MMM")</div>
                                    <a href="/admin/production/hub/@p.Id" class="btn btn-sm btn-outline-dark w-100">Open Hub</a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@* --- QUICK ADD MODAL --- *@
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">Add New Production</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showModal = false"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Production Title</label>
                        <input type="text" class="form-control" @bind="editingProd.Title" placeholder="e.g. Hamlet" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Category</label>
                        <select class="form-select" @bind="editingProd.CategoryId">
                            <option value="0">-- Select Category --</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold">Start Date</label>
                            <input type="date" class="form-control" @bind="editingProd.StartDate" />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-bold">End Date</label>
                            <input type="date" class="form-control" @bind="editingProd.EndDate" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary" @onclick="() => showModal = false">Cancel</button>
                    <button class="btn btn-primary px-4 fw-bold" @onclick="Save">Create Production</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Production> productions = new();
    private List<ProductionCategory> categories = new();
    private bool isLoading = true;
    private bool showModal = false;
    private Production editingProd = new();
    private int totalGaps = 0;
    private int next30Days = 0;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        using var context = await DbFactory.CreateDbContextAsync();
        categories = await context.ProductionCategories.OrderBy(c => c.Name).ToListAsync();
        productions = await context.Productions.Include(p => p.CrewAssignments).ToListAsync();
        
        totalGaps = productions.Where(p => p.StartDate >= DateTime.Today).Count(p => HasGaps(p));
        next30Days = productions.Count(p => p.StartDate >= DateTime.Today && p.StartDate <= DateTime.Today.AddDays(30));
        isLoading = false;
    }

    private bool HasGaps(Production p) => p.CrewAssignments.Any(c => c.IsRequired && string.IsNullOrEmpty(c.ExternalName) && c.MemberId == null);

    private void OpenAddModal()
    {
        editingProd = new Production { StartDate = DateTime.Today, EndDate = DateTime.Today.AddDays(7) };
        showModal = true;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(editingProd.Title) || editingProd.CategoryId == 0) return;

        using var context = await DbFactory.CreateDbContextAsync();
        context.Productions.Add(editingProd);
        await context.SaveChangesAsync();
        
        showModal = false;
        await LoadData();
        Nav.NavigateTo($"/admin/production/hub/{editingProd.Id}");
    }
}