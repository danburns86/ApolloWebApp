@page "/reports/ProductionDashboard"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Production Reports</PageTitle>

<div class="container py-4 max-w-6xl">
    <div class="mb-5 d-flex justify-content-between align-items-end">
        <div>
            <nav aria-label="breadcrumb">
              <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="/reports">Master Reports</a></li>
                <li class="breadcrumb-item active" aria-current="page">Production</li>
              </ol>
            </nav>
            <h2 class="fw-bold mb-0 text-dark">Production Reporting</h2>
            <p class="text-muted mb-0">Specialized exports for show personnel, marketing, and technical riders.</p>
        </div>
        <div class="text-end">
            <i class="bi bi-bar-chart-line fs-1 text-primary opacity-25"></i>
        </div>
    </div>

    <div class="row g-4">
        @* 1. THE TECH WING *@
        <div class="col-md-6">
            <h6 class="fw-bold mb-3 text-uppercase small text-muted"><i class="bi bi-wrench-adjustable me-2"></i>Technical & Logistics</h6>
            <div class="list-group shadow-sm border-0">
                <a href="/reports/Production/Crib" class="list-group-item list-group-item-action p-4">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div>
                            <h6 class="fw-bold mb-1">Production Crib Sheet</h6>
                            <p class="mb-0 small text-muted">A "one-pager" for Duty Techs/SMs. Includes hire info, access times, and full tech rider.</p>
                        </div>
                        <i class="bi bi-printer fs-4 text-primary"></i>
                    </div>
                </a>
                <a href="/reports/Production/Rota" class="list-group-item list-group-item-action p-4">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div>
                            <h6 class="fw-bold mb-1">Crew Rota & Dep List</h6>
                            <p class="mb-0 small text-muted">Master crew assignments vs. night-by-night performance overrides.</p>
                        </div>
                        <i class="bi bi-people fs-4 text-primary"></i>
                    </div>
                </a>
            </div>
        </div>

        @* 2. THE MARKETING WING *@
        <div class="col-md-6">
            <h6 class="fw-bold mb-3 text-uppercase small text-muted"><i class="bi bi-megaphone me-2"></i>Programme & Marketing</h6>
            <div class="list-group shadow-sm border-0">
                <a href="/reports/Production/Programme" class="list-group-item list-group-item-action p-4">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div>
                            <h6 class="fw-bold mb-1">Programme Export</h6>
                            <p class="mb-0 small text-muted">High-density text list of crew and programme extras for the designer.</p>
                        </div>
                        <i class="bi bi-file-earmark-text fs-4 text-success"></i>
                    </div>
                </a>
                <a href="/reports/Production/Overview" class="list-group-item list-group-item-action p-4">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div>
                            <h6 class="fw-bold mb-1">Seasonal Overview</h6>
                            <p class="mb-0 small text-muted">A headline-only list of all upcoming shows across all categories.</p>
                        </div>
                        <i class="bi bi-calendar3 fs-4 text-success"></i>
                    </div>
                </a>
            </div>
        </div>

        @* 3. THE MANAGEMENT WING *@
        <div class="col-12 mt-2">
             <h6 class="fw-bold mb-3 text-uppercase small text-muted"><i class="bi bi-shield-lock me-2"></i>Management & Gaps</h6>
             <div class="row g-3">
                 <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="fw-bold mb-1">Gaps Report</h6>
                                <p class="mb-0 small text-muted">Filterable list of uncrewed 'Required' roles.</p>
                            </div>
                            <a href="/reports/Production/Gaps" class="btn btn-sm btn-danger px-3 fw-bold">Run Report</a>
                        </div>
                    </div>
                 </div>
                 <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="fw-bold mb-1">Upcoming Crewing Status</h6>
                                <p class="mb-0 small text-muted">Detailed view of who is doing what in the coming weeks.</p>
                            </div>
                            <a href="/reports/Production/UpcomingCrewing" class="btn btn-sm btn-outline-dark px-3 fw-bold">Run Report</a>
                        </div>
                    </div>
                 </div>
             </div>
        </div>
    </div>
</div>

<style>
    .list-group-item {
        border-left: 4px solid transparent;
        transition: all 0.2s ease;
    }
    .list-group-item:hover {
        border-left-color: var(--bs-primary);
        background-color: #fcfcfc;
        transform: translateX(5px);
    }
</style>