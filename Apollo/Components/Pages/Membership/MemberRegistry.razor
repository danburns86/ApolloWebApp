@page "/admin/members"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Member Registry</PageTitle>

<div class="container-fluid px-4 py-4 max-w-7xl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Member Registry</h2>
            <p class="text-muted mb-0">Manage personnel and technical team eligibility.</p>
        </div>
        <div class="d-flex gap-2">
            <input type="text" class="form-control" placeholder="Search members..." @bind="searchQuery" @bind:event="oninput" @onkeyup="ApplyFilter" style="width: 300px;" />
            <a href="/admin/members/import" class="btn btn-outline-primary"><i class="bi bi-upload me-2"></i>Sync MemberMojo</a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="card shadow-sm border-0 border-top border-primary border-4">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4">Tech Team</th>
                            <th>Name</th>
                            <th>Contact</th>
                            <th>Status</th>
                            <th>Reported Interests</th>
                            <th class="text-end px-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in filteredMembers)
                        {
                            <tr class="@(member.IsTechTeam ? "table-primary table-opacity-10" : "")">
                                <td class="px-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox"
                                               checked="@member.IsTechTeam"
                                               @onchange="@(async (e) => await ToggleTechTeam(member, e))" />
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold">@member.FullName</div>
                                    <div class="small text-muted">#@member.MemberNumber</div>
                                </td>
                                <td>
                                    <div class="small"><i class="bi bi-envelope me-1"></i>@member.Email</div>
                                    <div class="small"><i class="bi bi-phone me-1"></i>@member.MobileNumber</div>
                                </td>
                                <td>
                                    <span class="badge @(member.MembershipStatus == "Active" ? "bg-success" : "bg-danger")">
                                        @member.MembershipStatus
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        @if (member.SkillLXOp)
                                        {
                                            <span class="badge bg-light text-dark border">LX</span>
                                        }
                                        @if (member.SkillSoundOp)
                                        {
                                            <span class="badge bg-light text-dark border">SND</span>
                                        }
                                        @if (member.SkillStageManager)
                                        {
                                            <span class="badge bg-light text-dark border">SM</span>
                                        }
                                    </div>
                                </td>
                                <td class="text-end px-4">
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ViewDetails(member)">Details</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* MEMBER PROFILE MODAL - 360 VIEW *@
@if (showDetailsModal && selectedMember != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); overflow-y: auto; z-index: 1050;">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-dark text-white border-0">
                    <h5 class="modal-title fw-bold">Member 360: @selectedMember.FullName</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDetails"></button>
                </div>
                <div class="modal-body p-0 bg-light">
                    @* Tab Navigation *@
                    <ul class="nav nav-tabs px-3 pt-2 bg-white">
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "profile" ? "active fw-bold" : "")" @onclick='() => activeTab = "profile"'>Profile & Skills</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "history" ? "active fw-bold" : "")" @onclick='() => activeTab = "history"'>Crewing & Keys</button>
                        </li>
                    </ul>

                    <div class="p-4">
                        @if (activeTab == "profile")
                        {
                            <div class="row g-4">
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm p-3 mb-3">
                                        <h6 class="fw-bold border-bottom pb-2 mb-3">Identity & Status</h6>
                                        <p class="mb-1 small text-muted">Member Number</p>
                                        <p class="fw-bold">#@selectedMember.MemberNumber</p>
                                        <p class="mb-1 small text-muted">Contact</p>
                                        <div class="mb-1 small">@selectedMember.Email</div>
                                        <div class="small">@selectedMember.MobileNumber</div>
                                    </div>
                                    <div class="card border-0 shadow-sm p-3">
                                        <h6 class="fw-bold border-bottom pb-2 mb-3">Safety & Compliance</h6>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>First Aider</span>
                                            <i class="bi @(selectedMember.IsFirstAider ? "bi-check-circle-fill text-success" : "bi-x-circle text-muted")"></i>
                                        </div>
                                        <div class="d-flex justify-content-between">
                                            <span>DBS Checked</span>
                                            <i class="bi @(selectedMember.HasDBS ? "bi-check-circle-fill text-success" : "bi-x-circle text-muted")"></i>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div class="card border-0 shadow-sm p-3">
                                        <h6 class="fw-bold border-bottom pb-2 mb-3">Mojo Interests</h6>
                                        <div class="row g-2">
                                            @foreach (var skill in GetSkillDisplayList(selectedMember))
                                            {
                                                <div class="col-6 col-md-4">
                                                    <div class="p-2 border rounded @(skill.IsSet ? "bg-primary-subtle border-primary" : "bg-white") small d-flex justify-content-between">
                                                        @skill.Name @if(skill.IsSet){
                                                        <i class="bi bi-check-lg"></i>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                        else
                    {
                        <div class="row g-4">
                            <div class="col-md-7">
                                <h6 class="fw-bold text-muted small text-uppercase mb-3">Crewing History</h6>
                                <div class="list-group shadow-sm">
                                    @if (!memberCrewing.Any())
                                    {
                                        <div class="list-group-item italic text-muted">No past crewing assignments found.</div>
                                    }
                                    @foreach (var crew in memberCrewing)
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center">
                                            <div>
                                                <div class="fw-bold">@crew.Production?.Title</div>
                                                <small class="text-muted">@(crew.Role?.Name ?? crew.CustomRoleName)</small>
                                            </div>
                                            <div class="badge bg-light text-dark">@crew.Production?.StartDate.ToString("MMM yyyy")</div>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-5">
                                <h6 class="fw-bold text-muted small text-uppercase mb-3">Key Allocation</h6>
                                <div class="card border-0 shadow-sm p-3 bg-white">
                                    <label class="small fw-bold text-primary mb-2">Permanent Keys Held</label>
                                    @if (!memberKeys.Any())
                                    {
                                        <p class="small italic text-muted">No permanent keys assigned to this name.</p>
                                    }
                                    else
                                    {
                                        @foreach (var k in memberKeys)
                                        {
                                            <div class="fw-bold mb-1"><i class="bi bi-key-fill text-warning me-2"></i>@k.Lock?.LockCode (@k.Lock?.Name)</div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer border-0">
                <button class="btn btn-secondary" @onclick="CloseDetails">Close</button>
                <button class="btn btn-primary px-4 fw-bold" @onclick="SaveChanges">Save Profile Changes</button>
            </div>
        </div>
    </div>
</div>
}

@code {
    private List<Member> allMembers = new();
    private List<Member> filteredMembers = new();
    private string searchQuery = "";
    private bool isLoading = true;
    private string activeTab = "profile";
    private List<ProductionCrew> memberCrewing = new();
    private List<KeyRecord> memberKeys = new();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        using var context = await DbFactory.CreateDbContextAsync();
        allMembers = await context.Members.OrderByDescending(m => m.IsTechTeam).ThenBy(m => m.LastName).ToListAsync();
        ApplyFilter();
        isLoading = false;
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) filteredMembers = allMembers.ToList();
        else
        {
            var q = searchQuery.ToLower();
            filteredMembers = allMembers.Where(m => m.FirstName.ToLower().Contains(q) || m.LastName.ToLower().Contains(q) || m.MemberNumber.Contains(q)).ToList();
        }
    }

    private async Task ToggleTechTeam(Member member, ChangeEventArgs e)
    {
        member.IsTechTeam = (bool)(e.Value ?? false);
        using var context = await DbFactory.CreateDbContextAsync();
        context.Members.Update(member);
        await context.SaveChangesAsync();
        await LoadData();
    }

    private bool showDetailsModal = false;
    private Member? selectedMember;

    private async Task ViewDetails(Member member)
    {
        selectedMember = member;
        activeTab = "profile";
        
        using var context = await DbFactory.CreateDbContextAsync();
        // Fetch Crewing
        memberCrewing = await context.ProductionCrews
            .Include(c => c.Production)
            .Include(c => c.Role)
            .Where(c => c.MemberId == member.Id)
            .OrderByDescending(c => c.Production!.StartDate)
            .ToListAsync();

        // Fetch Keys by name match
        memberKeys = await context.Keys
            .Include(k => k.Lock)
            .Where(k => k.IssuedToName == member.FullName && k.Status == "Issued")
            .ToListAsync();

        showDetailsModal = true;
    }

    private void CloseDetails() { showDetailsModal = false; selectedMember = null; }

    private async Task SaveChanges()
    {
        if (selectedMember != null)
        {
            using var context = await DbFactory.CreateDbContextAsync();
            context.Members.Update(selectedMember);
            await context.SaveChangesAsync();
            await LoadData();
            CloseDetails();
        }
    }

    private List<(string Name, bool IsSet)> GetSkillDisplayList(Member m)
    {
        return new List<(string Name, bool IsSet)> {
            ("LX Design", m.SkillLXDesign), ("LX Op", m.SkillLXOp),
            ("Snd Design", m.SkillSoundDesign), ("Snd Op", m.SkillSoundOp),
            ("Stage Manager", m.SkillStageManager), ("Stage Crew", m.SkillStageCrew),
            ("Wardrobe", m.SkillWardrobe), ("Set Build", m.SkillSetBuild),
            ("Bar", m.SkillBar), ("FOH", m.SkillFOH)
        };
    }
}