@page "/admin/assets/reports/lemon"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = SystemPermissions.ViewAssets)]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>The Lemon Report</PageTitle>

<div class="container-fluid px-4 py-4 max-w-7xl">
    <div class="d-flex justify-content-between align-items-center mb-4 d-print-none">
        <div>
            <h2 class="fw-bold mb-0 text-danger">Equipment Reliability "Lemon" Report</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a href="/admin/assets/reports">Reports Dashboard</a></li>
                    <li class="breadcrumb-item active">Lemon Report</li>
                </ol>
            </nav>
        </div>
        <button class="btn btn-outline-danger fw-bold" onclick="window.print()">
            <i class="bi bi-printer me-2"></i>Print Analytics
        </button>
    </div>

    <div class="alert alert-info d-flex align-items-center d-print-none border-0 shadow-sm mb-4">
        <i class="bi bi-info-circle-fill fs-4 me-3"></i>
        <div>
            <strong>How is this calculated?</strong> This report counts all Maintenance Snags (past and present) linked to specific assets.
            Items with <strong>3 or more faults</strong> are flagged as "Lemons" to help you decide on replacement vs. repair.
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-danger"></div></div>
    }
    else
    {
        <div class="card shadow-sm border-0 border-top border-danger border-4">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0">Reliability Ranking</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Asset Tag</th>
                                <th>Equipment Name</th>
                                <th>Category</th>
                                <th class="text-center">Total Faults</th>
                                <th>Reliability Rating</th>
                                <th class="text-end pe-4">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!lemonData.Any())
                            {
                                <tr><td colspan="6" class="text-center py-4 text-muted">No maintenance history found for current assets.</td></tr>
                            }
                            @foreach (var item in lemonData)
                            {
                                <tr class="@(item.FaultCount >= 3 ? "table-warning" : "")">
                                    <td class="ps-4 font-monospace fw-bold">@item.AssetTag</td>
                                    <td>
                                        <div class="fw-bold">@item.Name</div>
                                        <div class="small text-muted">@item.Manufacturer @item.Model</div>
                                    </td>
                                    <td><span class="badge bg-light text-dark border">@item.Category</span></td>
                                    <td class="text-center">
                                        <span class="fs-5 fw-bold @(item.FaultCount >= 3 ? "text-danger" : "")">@item.FaultCount</span>
                                    </td>
                                    <td>
                                        @if (item.FaultCount >= 5)
                                        {
                                            <span class="badge bg-danger text-uppercase px-3"><i class="bi bi-exclamation-triangle-fill me-1"></i> Critical Lemon</span>
                                        }
                                        else if (item.FaultCount >= 3)
                                        {
                                            <span class="badge bg-warning text-dark text-uppercase px-3">Unreliable</span>
                                        }
                                        else if (item.FaultCount > 0)
                                        {
                                            <span class="badge bg-info text-uppercase px-3">Normal Wear</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success text-uppercase px-3">Solid</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <span class="small fw-bold">@item.CurrentStatus</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<LemonSummary> lemonData = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        // We pull assets and their issues to calculate frequency
        var assets = await context.Assets
            .Include(a => a.Category)
            .Include(a => a.MaintenanceIssues)
            .ToListAsync();

        lemonData = assets.Select(a => new LemonSummary
        {
            AssetTag = a.AssetTag,
            Name = a.Name,
            Manufacturer = a.Manufacturer ?? "",
            Model = a.Model ?? "",
            Category = a.Category?.Name ?? "Uncategorized",
            FaultCount = a.MaintenanceIssues.Count,
            CurrentStatus = a.Status.ToString(),
        })
        .OrderByDescending(x => x.FaultCount)
        .ThenBy(x => x.AssetTag)
        .ToList();

        isLoading = false;
    }

    private class LemonSummary
    {
        public string AssetTag { get; set; } = "";
        public string Name { get; set; } = "";
        public string Manufacturer { get; set; } = "";
        public string Model { get; set; } = "";
        public string Category { get; set; } = "";
        public int FaultCount { get; set; }
        public string CurrentStatus { get; set; } = "";
    }
}