@page "/admin/assets/reports/compliance"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = SystemPermissions.ViewAssets)]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Safety Compliance Report</PageTitle>

<div class="container-fluid px-4 py-4 max-w-7xl">
    <div class="d-flex justify-content-between align-items-center mb-4 d-print-none">
        <div>
            <h2 class="fw-bold mb-0 text-danger">Compliance Action Report</h2>
            <p class="text-muted">Overdue or expiring inspections (30-day window).</p>
        </div>
        <button class="btn btn-danger fw-bold" onclick="window.print()"><i class="bi bi-printer me-2"></i>Print Compliance Audit</button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="card shadow-sm border-0 border-top border-danger border-4 mb-4">
            <div class="card-header bg-white py-3"><h6 class="fw-bold mb-0">Expired or Failing Tests</h6></div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0 small">
                    <thead class="table-dark">
                        <tr>
                            <th>Tag</th>
                            <th>Asset Name</th>
                            <th>Test Type</th>
                            <th>Expiry Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in reportData.Where(x => (x.NextPATDue < DateTime.Now) || (x.NextLOLERDue < DateTime.Now)))
                        {
                            <tr class="table-danger">
                                <td class="fw-bold">@a.AssetTag</td>
                                <td>@a.Name</td>
                                <td>@(a.RequiresPAT && a.NextPATDue < DateTime.Now ? "PAT" : "") @(a.RequiresLOLER && a.NextLOLERDue < DateTime.Now ? "LOLER" : "")</td>
                                <td class="fw-bold">@((a.NextPATDue < a.NextLOLERDue || !a.RequiresLOLER ? a.NextPATDue : a.NextLOLERDue)?.ToShortDateString())</td>
                                <td>OVERDUE</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card shadow-sm border-0 border-top border-warning border-4">
            <div class="card-header bg-white py-3"><h6 class="fw-bold mb-0">Upcoming Expirations (Next 30 Days)</h6></div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th>Tag</th>
                            <th>Asset Name</th>
                            <th>Requirement</th>
                            <th>Expiry Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in reportData.Where(x => (x.NextPATDue >= DateTime.Now) && (x.NextLOLERDue >= DateTime.Now)))
                        {
                            <tr>
                                <td class="fw-bold">@a.AssetTag</td>
                                <td>@a.Name</td>
                                <td>@(a.RequiresPAT ? "PAT" : "") @(a.RequiresLOLER ? "LOLER" : "")</td>
                                <td>@((a.NextPATDue < a.NextLOLERDue || !a.RequiresLOLER ? a.NextPATDue : a.NextLOLERDue)?.ToShortDateString())</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<Asset> reportData = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var horizon = DateTime.Now.AddDays(30);
        
        reportData = await context.Assets
            .Where(a => (a.RequiresPAT && a.NextPATDue < horizon) || (a.RequiresLOLER && a.NextLOLERDue < horizon))
            .OrderBy(a => a.NextPATDue)
            .ToListAsync();
        isLoading = false;
    }
}