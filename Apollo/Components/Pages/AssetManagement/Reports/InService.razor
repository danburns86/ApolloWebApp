@page "/admin/assets/reports/inservice"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = SystemPermissions.ViewAssets)]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Assets In Service</PageTitle>

<div class="container-fluid px-4 py-4 max-w-7xl">
    <div class="d-flex justify-content-between align-items-center mb-4 d-print-none">
        <div>
            <h2 class="fw-bold mb-0">Assets In Service</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a href="/admin/assets/reports">Reports Dashboard</a></li>
                    <li class="breadcrumb-item active">In Service</li>
                </ol>
            </nav>
        </div>
        <button class="btn btn-outline-primary" onclick="window.print()"><i class="bi bi-printer me-2"></i>Print</button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="card shadow-sm border-0 border-top border-success border-4">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0 text-success">Active Onsite Inventory (@reportData.Count items)</h5>
            </div>
            <div class="card-body p-0 text-nowrap">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tag</th>
                            <th>Name / Details</th>
                            <th>Current Location</th>
                            <th class="text-end px-4">Replacement Cost</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var asset in reportData)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@asset.AssetTag</td>
                                <td><div class="fw-bold">@asset.Name</div><div class="small text-muted">@asset.Manufacturer @asset.Model</div></td>
                                <td>@(asset.Room?.Name ?? "Unassigned")</td>
                                <td class="text-end px-4">£@(asset.ReplacementCost?.ToString("N2") ?? "0.00")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<Asset> reportData = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        reportData = await context.Assets
            .Include(a => a.Category)
            .Include(a => a.Room)
            .Where(a => a.Status == AssetStatus.Active && !a.IsOffsite)
            .OrderBy(a => a.AssetTag)
            .ToListAsync();
        isLoading = false;
    }
}