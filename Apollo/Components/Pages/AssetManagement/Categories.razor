@page "/admin/assets/categories"
@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = SystemPermissions.ManageAssets)]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Asset Categories & ID Engine</PageTitle>

<div class="container-fluid px-4 py-4 max-w-7xl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Asset Categories</h2>
            <p class="text-muted mb-0">Manage inventory groups and ID generation sequences.</p>
        </div>
        <button class="btn btn-primary fw-bold shadow-sm" @onclick="OpenAddForm">
            <i class="bi bi-plus-lg me-2"></i>New Category
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="card shadow-sm border-0 border-top border-primary border-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3">Category Name</th>
                                <th class="py-3">Prefix</th>
                                <th class="py-3 text-center">Padding Length</th>
                                <th class="py-3 text-center">Next Sequence #</th>
                                <th class="py-3 fw-bold text-primary">Next ID Preview</th>
                                <th class="py-3 text-end px-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!categories.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No categories configured yet.</td>
                                </tr>
                            }
                            @foreach (var cat in categories)
                            {
                                <tr>
                                    <td class="px-4 fw-bold">@cat.Name</td>
                                    <td><span class="badge bg-secondary">@cat.Prefix</span></td>
                                    <td class="text-center">@cat.PaddingLength spaces</td>
                                    <td class="text-center">@cat.NextSequenceNumber</td>
                                    <td class="fw-bold text-primary">
                                        <i class="bi bi-upc-scan me-2"></i>@GetNextIdPreview(cat)
                                    </td>
                                    <td class="text-end px-4">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenEditForm(cat)">
                                            <i class="bi bi-pencil"></i> Edit
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (showForm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-light border-0">
                    <h5 class="modal-title fw-bold">@(editingCat.Id == 0 ? "Create Category" : "Edit Category")</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <EditForm Model="editingCat" OnValidSubmit="SaveCategory">
                    <DataAnnotationsValidator />
                    <div class="modal-body p-4">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">Category Name</label>
                            <InputText @bind-Value="editingCat.Name" class="form-control" placeholder="e.g. Lighting, Sound, Building" />
                            <ValidationMessage For="() => editingCat.Name" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">ID Prefix</label>
                            <InputText @bind-Value="editingCat.Prefix" class="form-control text-uppercase" placeholder="e.g. LX, SND, GEN" />
                            <ValidationMessage For="() => editingCat.Prefix" class="text-danger small" />
                            <div class="form-text">Short code used at the start of the Asset Tag.</div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Start Number</label>
                                <InputNumber @bind-Value="editingCat.NextSequenceNumber" class="form-control" min="1" />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Padding Length</label>
                                <InputNumber @bind-Value="editingCat.PaddingLength" class="form-control" min="1" max="10" />
                            </div>
                        </div>

                        <div class="alert alert-primary mb-0 border-0 shadow-sm">
                            <div class="small text-muted mb-1">Live ID Preview:</div>
                            <div class="fw-bold fs-5"><i class="bi bi-upc-scan me-2"></i>@GetNextIdPreview(editingCat)</div>
                        </div>

                    </div>
                    <div class="modal-footer border-0 bg-light">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary fw-bold px-4">Save Configuration</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<AssetCategory> categories = new();
    private bool isLoading = true;
    private bool showForm = false;
    private AssetCategory editingCat = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        isLoading = true;
        using var context = await DbFactory.CreateDbContextAsync();
        categories = await context.AssetCategories.OrderBy(c => c.Name).ToListAsync();
        isLoading = false;
    }

    private string GetNextIdPreview(AssetCategory cat)
    {
        if (string.IsNullOrWhiteSpace(cat.Prefix)) return "---";
        // Generates the zero-padded string (e.g., D4 turns 1 into 0001)
        string numberPart = cat.NextSequenceNumber.ToString($"D{cat.PaddingLength}");
        return $"{cat.Prefix.ToUpper()}-{numberPart}";
    }

    private void OpenAddForm()
    {
        editingCat = new AssetCategory { PaddingLength = 4, NextSequenceNumber = 1, IsActive = true };
        showForm = true;
    }

    private void OpenEditForm(AssetCategory cat)
    {
        editingCat = new AssetCategory
        {
            Id = cat.Id,
            Name = cat.Name,
            Prefix = cat.Prefix,
            NextSequenceNumber = cat.NextSequenceNumber,
            PaddingLength = cat.PaddingLength,
            IsActive = cat.IsActive
        };
        showForm = true;
    }

    private void CloseForm()
    {
        showForm = false;
    }

    private async Task SaveCategory()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        // Force prefix to uppercase before saving
        editingCat.Prefix = editingCat.Prefix.ToUpper().Trim();

        if (editingCat.Id == 0)
        {
            context.AssetCategories.Add(editingCat);
        }
        else
        {
            var existing = await context.AssetCategories.FindAsync(editingCat.Id);
            if (existing != null)
            {
                existing.Name = editingCat.Name;
                existing.Prefix = editingCat.Prefix;
                existing.NextSequenceNumber = editingCat.NextSequenceNumber;
                existing.PaddingLength = editingCat.PaddingLength;
            }
        }

        await context.SaveChangesAsync();
        await LoadCategories();
        showForm = false;
    }
}