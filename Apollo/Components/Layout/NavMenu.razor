@using Apollo.Models
@using Apollo.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

@{
    var logoUrl = Config?.NavbarLogoUrl ?? "/images/default-logo.png";
    var theatreName = Config?.TheatreName ?? "APOLLO";
    var chevronClass = KeysExpanded ? "bi-chevron-down" : "bi-chevron-right";
    var maintChevronClass = MaintExpanded ? "bi-chevron-down" : "bi-chevron-right";
    var assetChevronClass = AssetsExpanded ? "bi-chevron-down" : "bi-chevron-right";
}

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    
    <div class="text-center py-3 border-bottom border-secondary mb-2" style="background-color: rgba(0,0,0,0.1);">
        <img src="@logoUrl" alt="Theatre Logo" style="max-height: 60px; max-width: 80%; object-fit: contain;" onerror="this.style.display='none';" />
        <div class="text-white fw-bold mt-1" style="font-size: 1.1rem; letter-spacing: 1px;">@theatreName</div>
    </div>

    <nav class="flex-column">
        
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-speedometer2 me-2" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        @* KEY MANAGEMENT GROUP *@
        <AuthorizeView Policy="@Apollo.Models.SystemPermissions.ViewInventory">
            <Authorized>
                <div class="nav-item px-3">
                    <button class="nav-link bg-transparent border-0 w-100 text-start shadow-none d-flex align-items-center" @onclick="ToggleKeys" @onclick:stopPropagation="true">
                        <span class="bi bi-key-fill me-2" aria-hidden="true"></span> Key Management
                        <span class="bi @chevronClass ms-auto" aria-hidden="true"></span>
                    </button>
                </div>
                
                @if (KeysExpanded)
                {
                    <div class="nav-item px-3 ms-3">
                        <NavLink class="nav-link py-2" href="keys/dashboard" Match="NavLinkMatch.All">
                            <span class="bi bi-house me-2" aria-hidden="true"></span> Key Dashboard
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 ms-3">
                        <NavLink class="nav-link py-2" href="keys" Match="NavLinkMatch.All">
                            <span class="bi bi-list-ul me-2" aria-hidden="true"></span> Key Inventory
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 ms-3">
                        <NavLink class="nav-link py-2" href="bunches" Match="NavLinkMatch.All">
                            <span class="bi bi-circle me-2" aria-hidden="true"></span> Bunches
                        </NavLink>
                    </div>

                    <AuthorizeView Policy="@Apollo.Models.SystemPermissions.ManageSystemSettings" Context="LockContext">
                        <Authorized>
                            <div class="nav-item px-3 ms-3">
                                <NavLink class="nav-link py-2" href="locks">
                                    <span class="bi bi-door-closed me-2" aria-hidden="true"></span> Lock Setup
                                </NavLink>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                    
                    <AuthorizeView Policy="@Apollo.Models.SystemPermissions.IssueReturn" Context="IssueContext">
                        <Authorized>
                            <div class="nav-item px-3 ms-3">
                                <NavLink class="nav-link py-2" href="issue-return">
                                    <span class="bi bi-arrow-left-right me-2" aria-hidden="true"></span> Issue & Return
                                </NavLink>
                            </div>
                        </Authorized>
                    </AuthorizeView>

                    <AuthorizeView Policy="@Apollo.Models.SystemPermissions.PerformAudit" Context="AuditContext">
                        <Authorized>
                            <div class="nav-item px-3 ms-3">
                                <NavLink class="nav-link py-2" href="audit">
                                    <span class="bi bi-clipboard-check me-2" aria-hidden="true"></span> Key Audit
                                </NavLink>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                }
            </Authorized>
        </AuthorizeView>

        @* MAINTENANCE HUB GROUP *@
        <AuthorizeView Policy="@Apollo.Models.SystemPermissions.ManageMaintenance">
            <Authorized>
                <div class="nav-item px-3">
                    <button class="nav-link bg-transparent border-0 w-100 text-start shadow-none d-flex align-items-center" @onclick="ToggleMaintenance" @onclick:stopPropagation="true">
                        <span class="bi bi-tools me-2" aria-hidden="true"></span> Maintenance Hub
                        <span class="bi @maintChevronClass ms-auto" aria-hidden="true"></span>
                    </button>
                </div>
                
                @if (MaintExpanded)
                {
                    <div class="nav-item px-3 ms-3">
                        <NavLink class="nav-link py-2" href="admin/maintenance/new">
                            <span class="bi bi-plus-circle me-2" aria-hidden="true"></span> Log New Job
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 ms-3">
                        <NavLink class="nav-link py-2" href="admin/maintenance" Match="NavLinkMatch.All">
                            <span class="bi bi-clipboard-pulse me-2" aria-hidden="true"></span> Triage Dashboard
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 ms-3">
                        <NavLink class="nav-link py-2" href="admin/maintenance/log">
                            <span class="bi bi-journal-text me-2" aria-hidden="true"></span> Master Log
                        </NavLink>
                    </div>
                }
            </Authorized>
        </AuthorizeView>

        @* ASSET TRACKING GROUP *@
        <AuthorizeView Policy="@Apollo.Models.SystemPermissions.ViewAssets">
            <Authorized>
                <div class="nav-item px-3">
                    <button class="nav-link bg-transparent border-0 w-100 text-start shadow-none d-flex align-items-center" @onclick="ToggleAssets" @onclick:stopPropagation="true">
                        <span class="bi bi-boxes me-2" aria-hidden="true"></span> Asset Tracking
                        <span class="bi @assetChevronClass ms-auto" aria-hidden="true"></span>
                    </button>
                </div>
                
                @if (AssetsExpanded)
                {
                    <div class="nav-item px-3 ms-3">
                        @* Added Match="NavLinkMatch.All" to prevent dashboard highlighting sub-items *@
                        <NavLink class="nav-link py-2" href="admin/assets/dashboard" Match="NavLinkMatch.All">
                            <span class="bi bi-speedometer2 me-2" aria-hidden="true"></span> Asset Dashboard
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 ms-3">
                        @* Added Match="NavLinkMatch.All" to prevent Registry highlighting when in Reports *@
                        <NavLink class="nav-link py-2" href="admin/assets" Match="NavLinkMatch.All">
                            <span class="bi bi-list-ul me-2" aria-hidden="true"></span> Registry
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 ms-3">
                        @* Added Match="NavLinkMatch.All" here too for consistency *@
                        <NavLink class="nav-link py-2" href="admin/assets/reports" Match="NavLinkMatch.All">
                            <span class="bi bi-bar-chart-fill me-2" aria-hidden="true"></span> Reports Hub
                        </NavLink>
                    </div>
                }
            </Authorized>
        </AuthorizeView>

        @* REPORTS & ANALYTICS GROUP *@
        <AuthorizeView Policy="@Apollo.Models.SystemPermissions.ManageSystemSettings" Context="ReportContext">
            <Authorized>
                <div class="nav-item px-3 mt-2 pt-2 border-top border-secondary border-opacity-25">
                    <button class="nav-link bg-transparent border-0 w-100 text-start shadow-none d-flex align-items-center" @onclick="ToggleReports" @onclick:stopPropagation="true">
                        <span class="bi bi-graph-up me-2" aria-hidden="true"></span> Reports & Analytics
                        <span class="bi @(ReportsExpanded ? "bi-chevron-down" : "bi-chevron-right") ms-auto" aria-hidden="true"></span>
                    </button>
                </div>
                
                @if (ReportsExpanded)
                {
                    <div class="nav-item px-3 ms-3">
                        <NavLink class="nav-link py-2" href="reports" Match="NavLinkMatch.All">
                            <span class="bi bi-grid-1x2 me-2" aria-hidden="true"></span> Master Hub
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 ms-3">
                        <NavLink class="nav-link py-2" href="keys/reports">
                            <span class="bi bi-key me-2" aria-hidden="true"></span> Key Reports
                        </NavLink>
                    </div>
                    <div class="nav-item px-3 ms-3">
                        <NavLink class="nav-link py-2" href="admin/maintenance/reports">
                            <span class="bi bi-tools me-2" aria-hidden="true"></span> Maintenance Lists
                        </NavLink>
                    </div>
                }
            </Authorized>
        </AuthorizeView>

        @* SYSTEM ADMIN SECTION *@
        <AuthorizeView Policy="@Apollo.Models.SystemPermissions.ManageSystemSettings">
            <Authorized>
                <div class="nav-item px-3 mt-2 pt-2 border-top border-secondary border-opacity-25">
                    <NavLink class="nav-link" href="admin/locations">
                        <i class="bi bi-geo-alt me-2"></i> Facilities
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin" Match="NavLinkMatch.All">
                        <span class="bi bi-gear me-2" aria-hidden="true"></span> Admin Dashboard
                    </NavLink>
                </div>
                <div class="nav-item px-3 ms-3">
                    <NavLink class="nav-link py-2" href="admin/assets/categories">
                        <span class="bi bi-tags me-2" aria-hidden="true"></span> ID Sequences
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        @* LOGOUT *@
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3 border-top border-secondary mt-2 pt-2">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="" />
                        <button type="submit" class="nav-link bg-transparent border-0 w-100 text-start shadow-none">
                            <span class="bi bi-box-arrow-left me-2" aria-hidden="true"></span> Logout (@UserDisplayName)
                        </button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private bool KeysExpanded = true;
    private bool MaintExpanded = true;
    private bool AssetsExpanded = true; // New
    private bool ReportsExpanded = false;
    private string UserDisplayName = "User";
    private PortalConfiguration? Config;

    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        Config = await db.PortalConfigurations.FirstOrDefaultAsync();

        var authState = await AuthStateTask;
        var user = authState.User;

        if (user?.Identity is { IsAuthenticated: true, Name: not null })
        {
            var appUser = await db.Users.FirstOrDefaultAsync(u => u.UserName == user.Identity.Name);
            UserDisplayName = appUser != null && !string.IsNullOrWhiteSpace(appUser.FirstName)
                ? $"{appUser.FirstName} {appUser.LastName}".Trim()
                : user.Identity.Name;
        }
    }

    private void ToggleKeys() => KeysExpanded = !KeysExpanded;
    private void ToggleMaintenance() => MaintExpanded = !MaintExpanded;
    private void ToggleAssets() => AssetsExpanded = !AssetsExpanded;
    private void ToggleReports() => ReportsExpanded = !ReportsExpanded;
}